Database store::DB
(
    Table CLEARING_MEMBER (MEMBER_ID VARCHAR(200) PRIMARY KEY, MEMBER_NAME VARCHAR(200), MEMBER_TYPE VARCHAR(200), STATUS VARCHAR(200), JOIN_DATE DATE, CREDIT_RATING VARCHAR(200), DEFAULT_FUND_CONTRIBUTION DOUBLE, GUARANTEE_FUND_CONTRIBUTION DOUBLE, IS_ACTIVE BOOLEAN, JURISDICTION VARCHAR(200), LEI VARCHAR(200), CURRENCY VARCHAR(200), CLEARING_HOUSE_ID VARCHAR(200))
    Table CLEARED_TRADE (CLEARED_TRADE_ID VARCHAR(200) PRIMARY KEY, CLEARING_DATE DATE, ORIGINAL_TRADE_ID VARCHAR(200), NOTIONAL DOUBLE, CLEARING_FEE DOUBLE, STATUS VARCHAR(200), PRODUCT_TYPE VARCHAR(200), CURRENCY VARCHAR(200), MATURITY_DATE DATE, IS_COMPRESSED BOOLEAN, COMPRESSION_DATE DATE, NOVATION_DATE DATE, CLEARING_MEMBER_ID VARCHAR(200), TRADE_ID VARCHAR(200))
    Table CCPMARGIN_CALL (CCP_MARGIN_ID VARCHAR(200) PRIMARY KEY, CALL_DATE DATE, INITIAL_MARGIN DOUBLE, VARIATION_MARGIN DOUBLE, ADDITIONAL_MARGIN DOUBLE, TOTAL_MARGIN DOUBLE, CURRENCY VARCHAR(200), STATUS VARCHAR(200), DUE_DATE DATE, PAID_AMOUNT DOUBLE, IS_PAID BOOLEAN, CALL_TYPE VARCHAR(200), CLEARING_MEMBER_ID VARCHAR(200))
    Table DEFAULT_FUND (FUND_ID VARCHAR(200) PRIMARY KEY, FUND_NAME VARCHAR(200), TOTAL_SIZE DOUBLE, UTILIZED_AMOUNT DOUBLE, AVAILABLE_AMOUNT DOUBLE, CURRENCY VARCHAR(200), AS_OF_DATE DATE, LAST_ASSESSMENT_DATE DATE, NEXT_ASSESSMENT_DATE DATE, IS_ADEQUATE BOOLEAN, TARGET_SIZE DOUBLE, CLEARING_HOUSE_ID VARCHAR(200))
    Table CLEARING_HOUSE (CLEARING_HOUSE_ID VARCHAR(200) PRIMARY KEY, NAME VARCHAR(200), SHORT_NAME VARCHAR(200), JURISDICTION VARCHAR(200), REGULATOR VARCHAR(200), IS_QCCP BOOLEAN, PRODUCT_TYPES VARCHAR(200), WEBSITE VARCHAR(200), LEI VARCHAR(200), MEMBER_COUNT INTEGER, DAILY_VOLUME DOUBLE, CURRENCY VARCHAR(200))
    Table NOVATION_REQUEST (NOVATION_ID VARCHAR(200) PRIMARY KEY, REQUEST_DATE DATE, REQUEST_TYPE VARCHAR(200), STATUS VARCHAR(200), STEPPING_IN_PARTY VARCHAR(200), STEPPING_OUT_PARTY VARCHAR(200), REMAINING_PARTY VARCHAR(200), NOTIONAL DOUBLE, CURRENCY VARCHAR(200), EFFECTIVE_DATE DATE, APPROVED_DATE DATE, IS_APPROVED BOOLEAN, CLEARED_TRADE_ID VARCHAR(200))
    Table TRADE_COMPRESSION (COMPRESSION_ID VARCHAR(200) PRIMARY KEY, COMPRESSION_DATE DATE, TRADES_BEFORE INTEGER, TRADES_AFTER INTEGER, NOTIONAL_BEFORE DOUBLE, NOTIONAL_AFTER DOUBLE, REDUCTION_PCT DOUBLE, STATUS VARCHAR(200), CYCLE VARCHAR(200), CURRENCY VARCHAR(200), PRODUCT_TYPE VARCHAR(200), IS_SUCCESSFUL BOOLEAN)
    Table PORTFOLIO_RECONCILIATION (RECON_ID VARCHAR(200) PRIMARY KEY, RECON_DATE DATE, TOTAL_POSITIONS INTEGER, MATCHED_POSITIONS INTEGER, UNMATCHED_POSITIONS INTEGER, MATCH_RATE DOUBLE, STATUS VARCHAR(200), FREQUENCY VARCHAR(200), DAYS_TO_RESOLVE INTEGER, IS_COMPLETE BOOLEAN, NOTIONAL_DIFFERENCE DOUBLE, CURRENCY VARCHAR(200))
    Table CLEARING_FEE (FEE_ID VARCHAR(200) PRIMARY KEY, FEE_DATE DATE, FEE_TYPE VARCHAR(200), AMOUNT DOUBLE, CURRENCY VARCHAR(200), FEE_SCHEDULE VARCHAR(200), VOLUME_DISCOUNT DOUBLE, NET_FEE DOUBLE, STATUS VARCHAR(200), INVOICE_ID VARCHAR(200), IS_PAID BOOLEAN, CLEARING_MEMBER_ID VARCHAR(200))
    Table POSITION_TRANSFER (TRANSFER_ID VARCHAR(200) PRIMARY KEY, TRANSFER_DATE DATE, FROM_MEMBER VARCHAR(200), TO_MEMBER VARCHAR(200), NOTIONAL DOUBLE, TRADE_COUNT INTEGER, STATUS VARCHAR(200), REASON VARCHAR(200), APPROVED_BY VARCHAR(200), EFFECTIVE_DATE DATE, CURRENCY VARCHAR(200), IS_REGULATORY BOOLEAN)

    Join ClearingHouse_ClearingMember(CLEARING_MEMBER.CLEARING_HOUSE_ID = CLEARING_HOUSE.CLEARING_HOUSE_ID)
    Join ClearingMember_ClearedTrade(CLEARED_TRADE.CLEARING_MEMBER_ID = CLEARING_MEMBER.MEMBER_ID)
    Join ClearingMember_CCPMarginCall(CCPMARGIN_CALL.CLEARING_MEMBER_ID = CLEARING_MEMBER.MEMBER_ID)
    Join ClearingHouse_DefaultFund(DEFAULT_FUND.CLEARING_HOUSE_ID = CLEARING_HOUSE.CLEARING_HOUSE_ID)
    Join ClearingMember_ClearingFee(CLEARING_FEE.CLEARING_MEMBER_ID = CLEARING_MEMBER.MEMBER_ID)
    Join ClearedTrade_NovationRequest(NOVATION_REQUEST.CLEARED_TRADE_ID = CLEARED_TRADE.CLEARED_TRADE_ID)
)


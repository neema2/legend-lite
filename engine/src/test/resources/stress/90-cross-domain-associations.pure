// ============================================================
// Cross-Domain Associations
// Links classes across domain boundaries for deep navigation
// ============================================================

// ---- Trading ↔ Products ----
Association cross::Trade_Instrument
{
    instrument: products::Instrument[1];
    trades: trading::Trade[*];
}

Association cross::Order_Instrument
{
    instrument: products::Instrument[1];
    orders: trading::Order[*];
}

// ---- Trading ↔ Positions ----
Association cross::Trade_Book
{
    book: positions::Book[1];
    trades: trading::Trade[*];
}

Association cross::Allocation_Book
{
    book: positions::Book[1];
    allocations: trading::Allocation[*];
}

// ---- Trading ↔ Org ----
Association cross::Trade_Trader
{
    trader: org::Trader[1];
    trades: trading::Trade[*];
}

// ---- Trading ↔ Counterparty ----
Association cross::Trade_Counterparty
{
    counterparty: counterparty::Counterparty[1];
    trades: trading::Trade[*];
}

// ---- Positions ↔ Org ----
Association cross::Book_Desk
{
    desk: org::Desk[1];
    books: positions::Book[*];
}

Association cross::Portfolio_PortfolioManager
{
    manager: org::PortfolioManager[1];
    portfolios: positions::Portfolio[*];
}

// ---- Positions ↔ Products ----
Association cross::Position_Instrument
{
    instrument: products::Instrument[1];
    positions: positions::Position[*];
}

// ---- Settlement ↔ Trading ----
Association cross::Settlement_Trade
{
    trade: trading::Trade[1];
    settlements: settlement::Settlement[*];
}

// ---- Settlement ↔ Products ----
Association cross::CorporateAction_Instrument
{
    instrument: products::Instrument[1];
    corporateActions: settlement::CorporateAction[*];
}


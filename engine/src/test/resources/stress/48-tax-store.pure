Database store::DB
(
    Table TAX_LOT (LOT_ID VARCHAR(200) PRIMARY KEY, ACQUIRE_DATE DATE, QUANTITY DOUBLE, COST_PRICE DOUBLE, COST_BASIS DOUBLE, CURRENT_VALUE DOUBLE, UNREALIZED_GAIN DOUBLE, TAX_METHOD VARCHAR(200), HOLDING_PERIOD VARCHAR(200), IS_OPEN BOOLEAN, CLOSE_DATE DATE, CURRENCY VARCHAR(200), POSITION_ID VARCHAR(200))
    Table WITHHOLDING_TAX (WITHHOLDING_ID VARCHAR(200) PRIMARY KEY, PAYMENT_DATE DATE, GROSS_AMOUNT DOUBLE, WITHHOLDING_RATE DOUBLE, WITHHOLDING_AMOUNT DOUBLE, NET_AMOUNT DOUBLE, CURRENCY VARCHAR(200), TAX_JURISDICTION VARCHAR(200), INCOME_TYPE VARCHAR(200), IS_RECLAIMABLE BOOLEAN, TREATY_RATE DOUBLE, STATUS VARCHAR(200))
    Table TAX_RECLAIM (RECLAIM_ID VARCHAR(200) PRIMARY KEY, RECLAIM_DATE DATE, RECLAIM_AMOUNT DOUBLE, CURRENCY VARCHAR(200), JURISDICTION VARCHAR(200), STATUS VARCHAR(200), SUBMITTED_DATE DATE, RECEIVED_DATE DATE, RECEIVED_AMOUNT DOUBLE, AGE_IN_DAYS INTEGER, CLAIM_TYPE VARCHAR(200), IS_PARTIAL BOOLEAN, WITHHOLDING_TAX_ID VARCHAR(200))
    Table COST_BASIS (COST_BASIS_ID VARCHAR(200) PRIMARY KEY, ORIGINAL_COST DOUBLE, ADJUSTED_COST DOUBLE, ADJUSTMENT_AMOUNT DOUBLE, ADJUSTMENT_REASON VARCHAR(200), ACQUISITION_DATE DATE, METHOD VARCHAR(200), CURRENCY VARCHAR(200), IS_ADJUSTED BOOLEAN, WASH_SALE_AMOUNT DOUBLE, ACCRUED_MARKET_DISCOUNT DOUBLE)
    Table TAX_JURISDICTION (JURISDICTION_ID VARCHAR(200) PRIMARY KEY, JURISDICTION_NAME VARCHAR(200), COUNTRY_CODE VARCHAR(200), DOMESTIC_RATE DOUBLE, TREATY_RATE DOUBLE, DIVIDEND_RATE DOUBLE, INTEREST_RATE DOUBLE, CAPITAL_GAINS_RATE DOUBLE, IS_ACTIVE BOOLEAN, EFFECTIVE_DATE DATE, LAST_UPDATED TIMESTAMP)
    Table TAX_TREATY (TREATY_ID VARCHAR(200) PRIMARY KEY, COUNTRY1 VARCHAR(200), COUNTRY2 VARCHAR(200), EFFECTIVE_DATE DATE, DIVIDEND_RATE DOUBLE, INTEREST_RATE DOUBLE, ROYALTY_RATE DOUBLE, CAPITAL_GAINS_EXEMPT BOOLEAN, IS_ACTIVE BOOLEAN, LAST_AMEND_DATE DATE, SOURCE VARCHAR(200), JURISDICTION_ID VARCHAR(200))
    Table TAX_REPORT (REPORT_ID VARCHAR(200) PRIMARY KEY, REPORT_TYPE VARCHAR(200), REPORT_YEAR INTEGER, TOTAL_INCOME DOUBLE, TOTAL_WITHHOLDING DOUBLE, TOTAL_GAINS DOUBLE, TOTAL_LOSSES DOUBLE, NET_TAXABLE DOUBLE, CURRENCY VARCHAR(200), STATUS VARCHAR(200), GENERATED_DATE DATE, FILING_DEADLINE DATE)
    Table CAPITAL_GAIN (GAIN_ID VARCHAR(200) PRIMARY KEY, SALE_DATE DATE, SALE_PROCEEDS DOUBLE, COST_BASIS DOUBLE, GAIN_LOSS DOUBLE, HOLDING_PERIOD VARCHAR(200), IS_SHORT_TERM BOOLEAN, WASH_SALE_DISALLOWED DOUBLE, ADJUSTED_GAIN DOUBLE, CURRENCY VARCHAR(200), TAX_RATE DOUBLE, TAX_LOT_ID VARCHAR(200))
    Table TAX_PROVISION (PROVISION_ID VARCHAR(200) PRIMARY KEY, PROVISION_DATE DATE, CURRENT_TAX DOUBLE, DEFERRED_TAX DOUBLE, TOTAL_PROVISION DOUBLE, EFFECTIVE_RATE DOUBLE, STATUTORY_RATE DOUBLE, RATE_DIFFERENCE DOUBLE, CURRENCY VARCHAR(200), JURISDICTION VARCHAR(200), PERIOD VARCHAR(200), STATUS VARCHAR(200), TAX_REPORT_ID VARCHAR(200))
    Table WHTRATE (RATE_ID VARCHAR(200) PRIMARY KEY, JURISDICTION VARCHAR(200), INCOME_TYPE VARCHAR(200), STANDARD_RATE DOUBLE, TREATY_RATE DOUBLE, EFFECTIVE_DATE DATE, EXPIRY_DATE DATE, IS_ACTIVE BOOLEAN, SOURCE VARCHAR(200), LAST_UPDATED TIMESTAMP, JURISDICTION_ID VARCHAR(200))

    Join TaxLot_CapitalGain(CAPITAL_GAIN.TAX_LOT_ID = TAX_LOT.LOT_ID)
    Join WithholdingTax_TaxReclaim(TAX_RECLAIM.WITHHOLDING_TAX_ID = WITHHOLDING_TAX.WITHHOLDING_ID)
    Join TaxJurisdiction_WHTRate(WHTRATE.JURISDICTION_ID = TAX_JURISDICTION.JURISDICTION_ID)
    Join TaxJurisdiction_TaxTreaty(TAX_TREATY.JURISDICTION_ID = TAX_JURISDICTION.JURISDICTION_ID)
    Join TaxReport_TaxProvision(TAX_PROVISION.TAX_REPORT_ID = TAX_REPORT.REPORT_ID)
)


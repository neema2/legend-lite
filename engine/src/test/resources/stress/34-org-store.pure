Database store::DB
(
    Table DESK (DESK_ID VARCHAR(200) PRIMARY KEY, NAME VARCHAR(200), DESK_TYPE VARCHAR(200), ASSET_CLASS VARCHAR(200), REGION VARCHAR(200), IS_ACTIVE BOOLEAN, HEAD_TRADER VARCHAR(200), COST_CENTER VARCHAR(200), FLOOR VARCHAR(200), BUILDING VARCHAR(200), PHONE VARCHAR(200), RISK_LIMIT DOUBLE, PNL_TARGET DOUBLE, BUSINESS_UNIT_ID VARCHAR(200))
    Table TRADER (TRADER_ID VARCHAR(200) PRIMARY KEY, FIRST_NAME VARCHAR(200), LAST_NAME VARCHAR(200), BADGE VARCHAR(200), EMAIL VARCHAR(200), HIRE_DATE DATE, SENIORITY VARCHAR(200), IS_ACTIVE BOOLEAN, SPECIALIZATION VARCHAR(200), LICENSE VARCHAR(200), MAX_NOTIONAL DOUBLE, PNL_YTD DOUBLE, PHONE VARCHAR(200), DESK_ID VARCHAR(200))
    Table PORTFOLIO_MANAGER (PM_ID VARCHAR(200) PRIMARY KEY, FIRST_NAME VARCHAR(200), LAST_NAME VARCHAR(200), EMAIL VARCHAR(200), STRATEGY VARCHAR(200), AUM DOUBLE, HIRE_DATE DATE, IS_ACTIVE BOOLEAN, PERFORMANCE_YTD DOUBLE, BENCHMARK VARCHAR(200), RISK_BUDGET DOUBLE, INVESTMENT_STYLE VARCHAR(200), CFA BOOLEAN, DESK_ID VARCHAR(200))
    Table BUSINESS_UNIT (BU_ID VARCHAR(200) PRIMARY KEY, NAME VARCHAR(200), HEAD VARCHAR(200), DIVISION VARCHAR(200), IS_ACTIVE BOOLEAN, HEADCOUNT INTEGER, BUDGET DOUBLE, COST_CENTER VARCHAR(200), REGION VARCHAR(200), ESTABLISHED_DATE DATE, DESCRIPTION VARCHAR(200), LEGAL_ENTITY_ID VARCHAR(200))
    Table LEGAL_ENTITY (LE_ID VARCHAR(200) PRIMARY KEY, NAME VARCHAR(200), JURISDICTION VARCHAR(200), LEI VARCHAR(200), ENTITY_TYPE VARCHAR(200), INCORPORATION_DATE DATE, REGISTRATION_NUMBER VARCHAR(200), REGULATORY_STATUS VARCHAR(200), IS_ACTIVE BOOLEAN, CAPITAL_BASE DOUBLE, PARENT_ENTITY_ID VARCHAR(200), TAX_ID VARCHAR(200), REGION_ID VARCHAR(200))
    Table REGION (REGION_ID VARCHAR(200) PRIMARY KEY, NAME VARCHAR(200), CODE VARCHAR(200), TIMEZONE VARCHAR(200), HEAD_OF_REGION VARCHAR(200), IS_ACTIVE BOOLEAN, HEADCOUNT INTEGER, REVENUE_TARGET DOUBLE, COST_TARGET DOUBLE, DESCRIPTION VARCHAR(200))
    Table COST_CENTER (COST_CENTER_ID VARCHAR(200) PRIMARY KEY, NAME VARCHAR(200), DEPARTMENT VARCHAR(200), BUDGET_AMOUNT DOUBLE, SPENT_AMOUNT DOUBLE, REMAINING_AMOUNT DOUBLE, FISCAL_YEAR INTEGER, MANAGER VARCHAR(200), IS_ACTIVE BOOLEAN, APPROVAL_THRESHOLD DOUBLE, CURRENCY VARCHAR(200))
    Table DEPARTMENT (DEPARTMENT_ID VARCHAR(200) PRIMARY KEY, NAME VARCHAR(200), HEAD VARCHAR(200), HEADCOUNT INTEGER, IS_ACTIVE BOOLEAN, BUDGET DOUBLE, FLOOR VARCHAR(200), BUILDING VARCHAR(200), PHONE VARCHAR(200), ESTABLISHED_DATE DATE, PARENT_DEPARTMENT_ID VARCHAR(200), COST_CENTER_ID VARCHAR(200), BUSINESS_UNIT_ID VARCHAR(200))
    Table TEAM (TEAM_ID VARCHAR(200) PRIMARY KEY, NAME VARCHAR(200), LEAD VARCHAR(200), TEAM_SIZE INTEGER, IS_ACTIVE BOOLEAN, FOCUS VARCHAR(200), FORMATION_DATE DATE, OBJECTIVE VARCHAR(200), PERFORMANCE_RATING DOUBLE, SLACK_CHANNEL VARCHAR(200), DEPARTMENT_ID VARCHAR(200))
    Table APPROVER (APPROVER_ID VARCHAR(200) PRIMARY KEY, FIRST_NAME VARCHAR(200), LAST_NAME VARCHAR(200), EMAIL VARCHAR(200), APPROVAL_LEVEL INTEGER, MAX_APPROVAL_AMOUNT DOUBLE, DEPARTMENT VARCHAR(200), IS_ACTIVE BOOLEAN, DELEGATE_TO VARCHAR(200), TITLE VARCHAR(200), CURRENCY VARCHAR(200), TEAM_ID VARCHAR(200))

    Join Desk_Trader(TRADER.DESK_ID = DESK.DESK_ID)
    Join Desk_BusinessUnit(DESK.BUSINESS_UNIT_ID = BUSINESS_UNIT.BU_ID)
    Join BusinessUnit_LegalEntity(BUSINESS_UNIT.LEGAL_ENTITY_ID = LEGAL_ENTITY.LE_ID)
    Join LegalEntity_Region(LEGAL_ENTITY.REGION_ID = REGION.REGION_ID)
    Join Department_Team(TEAM.DEPARTMENT_ID = DEPARTMENT.DEPARTMENT_ID)
    Join Department_CostCenter(DEPARTMENT.COST_CENTER_ID = COST_CENTER.COST_CENTER_ID)
    Join BusinessUnit_Department(DEPARTMENT.BUSINESS_UNIT_ID = BUSINESS_UNIT.BU_ID)
    Join Team_Approver(APPROVER.TEAM_ID = TEAM.TEAM_ID)
)


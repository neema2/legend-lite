Database store::DB
(
    Table TRADE_REPORT (REPORT_ID VARCHAR(200) PRIMARY KEY, REGIME VARCHAR(200), STATUS VARCHAR(200), SUBMISSION_DATE TIMESTAMP, REPORT_TYPE VARCHAR(200), UTI VARCHAR(200), USI VARCHAR(200), REPORTING_ENTITY VARCHAR(200), REPORTING_COUNTERPARTY VARCHAR(200), REJECT_REASON VARCHAR(200), RETRY_COUNT INTEGER, IS_LATE_REPORT BOOLEAN, DUE_DATE DATE, TRADE_ID VARCHAR(200))
    Table TRANSACTION_COST (TCA_ID VARCHAR(200) PRIMARY KEY, COST_BPS DOUBLE, IMPLEMENTATION_SHORTFALL DOUBLE, MARKET_IMPACT_BPS DOUBLE, BENCHMARK VARCHAR(200), ANALYSIS_DATE DATE, ARRIVAL_PRICE DOUBLE, EXECUTION_PRICE DOUBLE, VWAP_PRICE DOUBLE, CLOSING_PRICE DOUBLE, CURRENCY VARCHAR(200), IS_BEST_EXECUTION BOOLEAN, MODEL VARCHAR(200), EXECUTION_ID VARCHAR(200))
    Table REGULATORY_FILING (FILING_ID VARCHAR(200) PRIMARY KEY, FILING_TYPE VARCHAR(200), REGIME VARCHAR(200), FILING_DATE DATE, DUE_DATE DATE, STATUS VARCHAR(200), SUBMITTED_BY VARCHAR(200), APPROVED_BY VARCHAR(200), IS_AMENDMENT BOOLEAN, PREVIOUS_FILING_ID VARCHAR(200), REFERENCE_NUMBER VARCHAR(200), PERIOD_START DATE, PERIOD_END DATE)
    Table COMPLIANCE_ALERT (ALERT_ID VARCHAR(200) PRIMARY KEY, ALERT_TYPE VARCHAR(200), SEVERITY VARCHAR(200), TRIGGERED_DATE TIMESTAMP, DESCRIPTION VARCHAR(200), STATUS VARCHAR(200), ASSIGNED_TO VARCHAR(200), RESOLVED_DATE TIMESTAMP, RESOLUTION VARCHAR(200), IS_FALSE_POSITIVE BOOLEAN, RULE_ID VARCHAR(200), ESCALATION_LEVEL INTEGER, DUE_DATE DATE)
    Table SANCTIONS_SCREENING (SCREENING_ID VARCHAR(200) PRIMARY KEY, SCREENING_DATE TIMESTAMP, SCREENING_TYPE VARCHAR(200), LIST_TYPE VARCHAR(200), RESULT VARCHAR(200), MATCH_SCORE DOUBLE, MATCHED_NAME VARCHAR(200), STATUS VARCHAR(200), REVIEWED_BY VARCHAR(200), REVIEW_DATE TIMESTAMP, IS_FALSE_POSITIVE BOOLEAN, PROVIDER VARCHAR(200), COMPLIANCE_ALERT_ID VARCHAR(200))
    Table BEST_EXECUTION_REPORT (REPORT_ID VARCHAR(200) PRIMARY KEY, REPORT_DATE DATE, VENUE VARCHAR(200), ASSET_CLASS VARCHAR(200), EXECUTION_QUALITY DOUBLE, PRICE_IMPROVEMENT DOUBLE, FILL_RATE DOUBLE, AVG_LATENCY_MS INTEGER, ORDER_COUNT INTEGER, TOTAL_VOLUME DOUBLE, CURRENCY VARCHAR(200), IS_PASSING BOOLEAN, PERIOD VARCHAR(200))
    Table POSITION_LIMIT (LIMIT_ID VARCHAR(200) PRIMARY KEY, LIMIT_TYPE VARCHAR(200), REGIME VARCHAR(200), LIMIT_AMOUNT DOUBLE, CURRENT_POSITION DOUBLE, UTILIZATION_PCT DOUBLE, EFFECTIVE_DATE DATE, EXPIRY_DATE DATE, STATUS VARCHAR(200), IS_BREACHED BOOLEAN, LAST_CHECKED TIMESTAMP, REPORTING_THRESHOLD DOUBLE)
    Table TRADE_REPORT_STATUS (STATUS_ID VARCHAR(200) PRIMARY KEY, STATUS_DATE TIMESTAMP, PREVIOUS_STATUS VARCHAR(200), NEW_STATUS VARCHAR(200), REASON VARCHAR(200), UPDATED_BY VARCHAR(200), IS_AUTOMATIC BOOLEAN, TR_REPOSITORY VARCHAR(200), RESPONSE_CODE VARCHAR(200), RESPONSE_MESSAGE VARCHAR(200), TRADE_REPORT_ID VARCHAR(200))
    Table REGULATORY_CAPITAL (CAPITAL_ID VARCHAR(200) PRIMARY KEY, CALC_DATE DATE, RWA_AMOUNT DOUBLE, CAPITAL_REQUIREMENT DOUBLE, TIER1_CAPITAL DOUBLE, TIER2_CAPITAL DOUBLE, TOTAL_CAPITAL DOUBLE, CAPITAL_RATIO DOUBLE, LEVERAGE_RATIO DOUBLE, CURRENCY VARCHAR(200), FRAMEWORK VARCHAR(200), IS_COMPLIANT BOOLEAN, FILING_ID VARCHAR(200), LE_ID VARCHAR(200))
    Table LIQUIDITY_COVERAGE (LCR_ID VARCHAR(200) PRIMARY KEY, CALC_DATE DATE, HQLA DOUBLE, NET_CASH_OUTFLOWS DOUBLE, LCR DOUBLE, NSFR DOUBLE, CURRENCY VARCHAR(200), STRESS_SCENARIO VARCHAR(200), IS_COMPLIANT BOOLEAN, MINIMUM_REQUIRED DOUBLE, BUFFER DOUBLE, LAST_UPDATED TIMESTAMP, FILING_ID VARCHAR(200))

    Join TradeReport_TradeReportStatus(TRADE_REPORT_STATUS.TRADE_REPORT_ID = TRADE_REPORT.REPORT_ID)
    Join ComplianceAlert_SanctionsScreening(SANCTIONS_SCREENING.COMPLIANCE_ALERT_ID = COMPLIANCE_ALERT.ALERT_ID)
    Join RegulatoryFiling_RegulatoryCapital(REGULATORY_CAPITAL.FILING_ID = REGULATORY_FILING.FILING_ID)
    Join RegulatoryFiling_LiquidityCoverage(LIQUIDITY_COVERAGE.FILING_ID = REGULATORY_FILING.FILING_ID)
)


Database store::DB
(
    Table DAILY_PN_L (PNL_ID VARCHAR(200) PRIMARY KEY, PNL_DATE DATE, TOTAL_PN_L DOUBLE, REALIZED_PN_L DOUBLE, UNREALIZED_PN_L DOUBLE, NEW_TRADE_PN_L DOUBLE, CARRY_PN_L DOUBLE, FX_PN_L DOUBLE, COMMISSIONS DOUBLE, FEES DOUBLE, CURRENCY VARCHAR(200), IS_OFFICIAL BOOLEAN, PUBLISHED_TIME TIMESTAMP, VERSION INTEGER, MTD_PN_L_ID VARCHAR(200), BOOK_ID VARCHAR(200), DESK_ID VARCHAR(200), TRADER_ID VARCHAR(200))
    Table PN_LATTRIBUTION (ATTRIBUTION_ID VARCHAR(200) PRIMARY KEY, ATTRIBUTION_DATE DATE, CATEGORY VARCHAR(200), AMOUNT DOUBLE, CURRENCY VARCHAR(200), RISK_FACTOR VARCHAR(200), MODEL VARCHAR(200), CONFIDENCE DOUBLE, IS_RESIDUAL BOOLEAN, EXPLANATION VARCHAR(200), VERSION INTEGER, DAILY_PN_L_ID VARCHAR(200))
    Table HYPOTHETICAL_PN_L (HYPOTHETICAL_ID VARCHAR(200) PRIMARY KEY, SCENARIO_NAME VARCHAR(200), CALC_DATE DATE, HYPOTHETICAL_PN_L DOUBLE, CLEAN_PN_L DOUBLE, DELTA_APPROX DOUBLE, FULL_REVAL DOUBLE, CURRENCY VARCHAR(200), MODEL VARCHAR(200), IS_BACKTEST BOOLEAN, BACKTEST_DATE DATE, CONFIDENCE DOUBLE, DAILY_PN_L_ID VARCHAR(200))
    Table PN_LADJUSTMENT (ADJUSTMENT_ID VARCHAR(200) PRIMARY KEY, ADJUSTMENT_DATE DATE, ADJUSTMENT_TYPE VARCHAR(200), AMOUNT DOUBLE, REASON VARCHAR(200), APPROVED_BY VARCHAR(200), APPROVAL_DATE DATE, STATUS VARCHAR(200), CURRENCY VARCHAR(200), ORIGINAL_PN_L DOUBLE, ADJUSTED_PN_L DOUBLE, COMMENT VARCHAR(200), IS_REVERSED BOOLEAN, DAILY_PN_L_ID VARCHAR(200))
    Table REVENUE_ALLOCATION (ALLOCATION_ID VARCHAR(200) PRIMARY KEY, ALLOCATION_DATE DATE, REVENUE DOUBLE, ALLOCATION_BASIS VARCHAR(200), PERCENTAGE DOUBLE, ALLOCATED_AMOUNT DOUBLE, CURRENCY VARCHAR(200), PERIOD VARCHAR(200), IS_MANUAL_OVERRIDE BOOLEAN, OVERRIDE_BY VARCHAR(200), COMMENT VARCHAR(200), DAILY_PN_L_ID VARCHAR(200))
    Table ACCRUAL_ENTRY (ACCRUAL_ID VARCHAR(200) PRIMARY KEY, ACCRUAL_DATE DATE, ACCRUAL_TYPE VARCHAR(200), AMOUNT DOUBLE, START_DATE DATE, END_DATE DATE, DAY_COUNT INTEGER, RATE DOUBLE, CURRENCY VARCHAR(200), STATUS VARCHAR(200), IS_REVERSED BOOLEAN, REVERSAL_DATE DATE, DAILY_PN_L_ID VARCHAR(200))
    Table VALUATION_ADJUSTMENT (ADJUSTMENT_ID VARCHAR(200) PRIMARY KEY, ADJUSTMENT_TYPE VARCHAR(200), AMOUNT DOUBLE, CALC_DATE DATE, METHODOLOGY VARCHAR(200), CURRENCY VARCHAR(200), CONFIDENCE_LEVEL DOUBLE, PREVIOUS_AMOUNT DOUBLE, CHANGE_AMOUNT DOUBLE, APPROVED_BY VARCHAR(200), STATUS VARCHAR(200), IS_ACTIVE BOOLEAN, DAILY_PN_L_ID VARCHAR(200))
    Table PN_LEXPLAIN (EXPLAIN_ID VARCHAR(200) PRIMARY KEY, EXPLAIN_DATE DATE, MARKET_MOVE DOUBLE, CARRY_ROLL_DOWN DOUBLE, THETA DOUBLE, NEW_TRADE_IMPACT DOUBLE, CROSS_EFFECT DOUBLE, RESIDUAL DOUBLE, TOTAL_EXPLAINED DOUBLE, UNEXPLAINED DOUBLE, CURRENCY VARCHAR(200), MODEL VARCHAR(200), IS_COMPLETE BOOLEAN, DAILY_PN_L_ID VARCHAR(200))
    Table MTDPN_L (MTD_ID VARCHAR(200) PRIMARY KEY, MONTH_START_DATE DATE, AS_OF_DATE DATE, MTD_PN_L DOUBLE, MTD_REALIZED_PN_L DOUBLE, MTD_UNREALIZED_PN_L DOUBLE, MTD_FEES DOUBLE, MTD_COMMISSIONS DOUBLE, CURRENCY VARCHAR(200), TRADING_DAYS INTEGER, BEST_DAY DOUBLE, WORST_DAY DOUBLE, IS_FINALIZED BOOLEAN, YTD_PN_L_ID VARCHAR(200))
    Table YTDPN_L (YTD_ID VARCHAR(200) PRIMARY KEY, YEAR_START_DATE DATE, AS_OF_DATE DATE, YTD_PN_L DOUBLE, YTD_REALIZED_PN_L DOUBLE, YTD_UNREALIZED_PN_L DOUBLE, YTD_FEES DOUBLE, YTD_COMMISSIONS DOUBLE, CURRENCY VARCHAR(200), TRADING_DAYS INTEGER, BEST_MONTH DOUBLE, WORST_MONTH DOUBLE, ANNUALIZED_RETURN DOUBLE, IS_FINALIZED BOOLEAN)

    Join DailyPnL_PnLAttribution(PN_LATTRIBUTION.DAILY_PN_L_ID = DAILY_PN_L.PNL_ID)
    Join DailyPnL_PnLExplain(PN_LEXPLAIN.DAILY_PN_L_ID = DAILY_PN_L.PNL_ID)
    Join DailyPnL_PnLAdjustment(PN_LADJUSTMENT.DAILY_PN_L_ID = DAILY_PN_L.PNL_ID)
    Join DailyPnL_HypotheticalPnL(HYPOTHETICAL_PN_L.DAILY_PN_L_ID = DAILY_PN_L.PNL_ID)
    Join DailyPnL_AccrualEntry(ACCRUAL_ENTRY.DAILY_PN_L_ID = DAILY_PN_L.PNL_ID)
    Join DailyPnL_ValuationAdjustment(VALUATION_ADJUSTMENT.DAILY_PN_L_ID = DAILY_PN_L.PNL_ID)
    Join DailyPnL_RevenueAllocation(REVENUE_ALLOCATION.DAILY_PN_L_ID = DAILY_PN_L.PNL_ID)
    Join MTDPnL_DailyPnL(DAILY_PN_L.MTD_PN_L_ID = MTDPN_L.MTD_ID)
    Join YTDPnL_MTDPnL(MTDPN_L.YTD_PN_L_ID = YTDPN_L.YTD_ID)
)


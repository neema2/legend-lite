Database store::DB
(
    Table SALES_CREDIT (CREDIT_ID VARCHAR(200) PRIMARY KEY, CREDIT_AMOUNT DOUBLE, CREDIT_DATE DATE, CREDIT_TYPE VARCHAR(200), CURRENCY VARCHAR(200), SPLIT_PCT DOUBLE, STATUS VARCHAR(200), IS_OVERRIDE BOOLEAN, OVERRIDE_BY VARCHAR(200), ORIGINAL_AMOUNT DOUBLE, REGION VARCHAR(200), PRODUCT_AREA VARCHAR(200), SALES_PERSON_ID VARCHAR(200), TRADE_ID VARCHAR(200))
    Table SALES_PERSON (SALES_PERSON_ID VARCHAR(200) PRIMARY KEY, FIRST_NAME VARCHAR(200), LAST_NAME VARCHAR(200), EMAIL VARCHAR(200), REGION VARCHAR(200), TIER VARCHAR(200), HIRE_DATE DATE, IS_ACTIVE BOOLEAN, REVENUE_YTD DOUBLE, REVENUE_TARGET DOUBLE, CLIENT_COUNT INTEGER, SPECIALIZATION VARCHAR(200), PHONE VARCHAR(200), TERRITORY_ID VARCHAR(200), COMMISSION_STRUCTURE_ID VARCHAR(200), DESK_ID VARCHAR(200))
    Table CLIENT_COVERAGE (COVERAGE_ID VARCHAR(200) PRIMARY KEY, ROLE VARCHAR(200), START_DATE DATE, END_DATE DATE, PRODUCT_AREA VARCHAR(200), REGION VARCHAR(200), IS_ACTIVE BOOLEAN, COVERAGE_TYPE VARCHAR(200), REVENUE_SPLIT DOUBLE, LAST_CONTACT_DATE DATE, NOTES VARCHAR(200), SALES_PERSON_ID VARCHAR(200), COUNTERPARTY_ID VARCHAR(200))
    Table SALES_PIPELINE (PIPELINE_ID VARCHAR(200) PRIMARY KEY, DEAL_NAME VARCHAR(200), STAGE VARCHAR(200), EXPECTED_REVENUE DOUBLE, PROBABILITY DOUBLE, EXPECTED_CLOSE_DATE DATE, CURRENCY VARCHAR(200), PRODUCT_TYPE VARCHAR(200), CREATED_DATE DATE, LAST_UPDATED TIMESTAMP, IS_WON BOOLEAN, LOST_REASON VARCHAR(200), COMPETITOR_NAME VARCHAR(200), SALES_PERSON_ID VARCHAR(200))
    Table CLIENT_INTERACTION (INTERACTION_ID VARCHAR(200) PRIMARY KEY, INTERACTION_DATE TIMESTAMP, INTERACTION_TYPE VARCHAR(200), SUBJECT VARCHAR(200), DURATION INTEGER, OUTCOME VARCHAR(200), FOLLOW_UP_DATE DATE, ATTENDEES INTEGER, IS_FOLLOW_UP_COMPLETE BOOLEAN, CHANNEL VARCHAR(200), SENTIMENT VARCHAR(200), NOTES VARCHAR(200), SALES_PERSON_ID VARCHAR(200))
    Table REVENUE_BUDGET (BUDGET_ID VARCHAR(200) PRIMARY KEY, FISCAL_YEAR INTEGER, QUARTER INTEGER, BUDGET_AMOUNT DOUBLE, ACTUAL_AMOUNT DOUBLE, VARIANCE_AMOUNT DOUBLE, VARIANCE_PCT DOUBLE, CURRENCY VARCHAR(200), REGION VARCHAR(200), PRODUCT_AREA VARCHAR(200), IS_FINALIZED BOOLEAN, LAST_UPDATED TIMESTAMP, SALES_PERSON_ID VARCHAR(200))
    Table CLIENT_TIER (TIER_ID VARCHAR(200) PRIMARY KEY, TIER_NAME VARCHAR(200), MIN_REVENUE DOUBLE, MAX_REVENUE DOUBLE, SERVICE_LEVEL VARCHAR(200), DISCOUNT_PCT DOUBLE, IS_ACTIVE BOOLEAN, DESCRIPTION VARCHAR(200), REVIEW_FREQUENCY VARCHAR(200), LAST_REVIEW_DATE DATE)
    Table SALES_TERRITORY (TERRITORY_ID VARCHAR(200) PRIMARY KEY, NAME VARCHAR(200), REGION VARCHAR(200), COUNTRIES VARCHAR(200), HEADCOUNT INTEGER, REVENUE_TARGET DOUBLE, ACTUAL_REVENUE DOUBLE, IS_ACTIVE BOOLEAN, DESCRIPTION VARCHAR(200), MANAGER_NAME VARCHAR(200))
    Table COMMISSION_STRUCTURE (STRUCTURE_ID VARCHAR(200) PRIMARY KEY, STRUCTURE_NAME VARCHAR(200), COMMISSION_PCT DOUBLE, MIN_DEAL_SIZE DOUBLE, MAX_DEAL_SIZE DOUBLE, PRODUCT_AREA VARCHAR(200), EFFECTIVE_DATE DATE, EXPIRY_DATE DATE, IS_ACTIVE BOOLEAN, ACCELERATOR_PCT DOUBLE, CAP_AMOUNT DOUBLE, CURRENCY VARCHAR(200))
    Table CLIENT_ACTIVITY (ACTIVITY_ID VARCHAR(200) PRIMARY KEY, ACTIVITY_DATE DATE, ACTIVITY_TYPE VARCHAR(200), TRADE_COUNT INTEGER, TRADE_VOLUME DOUBLE, REVENUE DOUBLE, COMMISSION DOUBLE, PRODUCT_AREA VARCHAR(200), IS_ACTIVE BOOLEAN, CURRENCY VARCHAR(200), REGION VARCHAR(200), COVERAGE_ID VARCHAR(200))

    Join SalesCredit_SalesPerson(SALES_CREDIT.SALES_PERSON_ID = SALES_PERSON.SALES_PERSON_ID)
    Join SalesPerson_ClientCoverage(CLIENT_COVERAGE.SALES_PERSON_ID = SALES_PERSON.SALES_PERSON_ID)
    Join SalesPerson_Pipeline(SALES_PIPELINE.SALES_PERSON_ID = SALES_PERSON.SALES_PERSON_ID)
    Join SalesPerson_ClientInteraction(CLIENT_INTERACTION.SALES_PERSON_ID = SALES_PERSON.SALES_PERSON_ID)
    Join SalesPerson_RevenueBudget(REVENUE_BUDGET.SALES_PERSON_ID = SALES_PERSON.SALES_PERSON_ID)
    Join SalesPerson_Territory(SALES_PERSON.TERRITORY_ID = SALES_TERRITORY.TERRITORY_ID)
    Join SalesPerson_Commission(SALES_PERSON.COMMISSION_STRUCTURE_ID = COMMISSION_STRUCTURE.STRUCTURE_ID)
    Join ClientActivity_ClientCoverage(CLIENT_ACTIVITY.COVERAGE_ID = CLIENT_COVERAGE.COVERAGE_ID)
)


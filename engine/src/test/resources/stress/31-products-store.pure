Database store::DB
(
    Table INSTRUMENT (INSTRUMENT_ID VARCHAR(200) PRIMARY KEY, TICKER VARCHAR(200), NAME VARCHAR(200), ISIN VARCHAR(200), CUSIP VARCHAR(200), SEDOL VARCHAR(200), ASSET_CLASS VARCHAR(200), PRODUCT_TYPE VARCHAR(200), IS_ACTIVE BOOLEAN, LISTING_DATE DATE, MATURITY_DATE DATE, NOTIONAL_AMOUNT DOUBLE, CURRENCY VARCHAR(200), DESCRIPTION VARCHAR(200), ISSUE_DATE DATE, EQUITY_ID VARCHAR(200), BOND_ID VARCHAR(200), FUTURE_ID VARCHAR(200), FX_FORWARD_ID VARCHAR(200), SWAP_ID VARCHAR(200), CDS_ID VARCHAR(200), STRUCTURED_PRODUCT_ID VARCHAR(200), ETF_ID VARCHAR(200), CURRENCY_CODE VARCHAR(200), EXCHANGE_MIC VARCHAR(200), SECTOR_ID VARCHAR(200))
    Table EQUITY (EQUITY_ID VARCHAR(200) PRIMARY KEY, TICKER VARCHAR(200), COMPANY_NAME VARCHAR(200), SHARE_CLASS VARCHAR(200), MARKET_CAP DOUBLE, SHARES_OUTSTANDING DOUBLE, DIVIDEND_YIELD DOUBLE, PE_RATIO DOUBLE, BETA DOUBLE, PRIMARY_EXCHANGE VARCHAR(200), IS_ADR BOOLEAN, LOT_SIZE INTEGER, LAST_PRICE DOUBLE, PRICE_DATE DATE, INSTRUMENT_ID VARCHAR(200))
    Table BOND (BOND_ID VARCHAR(200) PRIMARY KEY, ISSUER_NAME VARCHAR(200), COUPON_RATE DOUBLE, COUPON_FREQUENCY INTEGER, FACE_VALUE DOUBLE, MATURITY_DATE DATE, ISSUE_DATE DATE, CREDIT_RATING VARCHAR(200), YIELD_TO_MATURITY DOUBLE, DURATION DOUBLE, CONVEXITY DOUBLE, IS_CALLABLE BOOLEAN, CALL_DATE DATE, CALL_PRICE DOUBLE, BOND_TYPE VARCHAR(200), CURRENCY VARCHAR(200), INSTRUMENT_ID VARCHAR(200), ISSUER_ID VARCHAR(200))
    Table OPTION (OPTION_ID VARCHAR(200) PRIMARY KEY, OPTION_TYPE VARCHAR(200), STRIKE_PRICE DOUBLE, EXPIRATION_DATE DATE, PREMIUM DOUBLE, IMPLIED_VOLATILITY DOUBLE, DELTA DOUBLE, GAMMA DOUBLE, THETA DOUBLE, VEGA DOUBLE, EXERCISE_STYLE VARCHAR(200), IS_IN_THE_MONEY BOOLEAN, UNDERLYING_PRICE DOUBLE, CONTRACT_SIZE INTEGER, OPEN_INTEREST INTEGER, UNDERLYING_ID VARCHAR(200))
    Table FUTURE (FUTURE_ID VARCHAR(200) PRIMARY KEY, CONTRACT_NAME VARCHAR(200), CONTRACT_MONTH VARCHAR(200), CONTRACT_YEAR INTEGER, TICK_SIZE DOUBLE, CONTRACT_SIZE INTEGER, LAST_TRADING_DATE DATE, FIRST_NOTICE_DATE DATE, SETTLEMENT_TYPE VARCHAR(200), MARGIN_REQUIRED DOUBLE, DAILY_LIMIT DOUBLE, OPEN_INTEREST INTEGER, INSTRUMENT_ID VARCHAR(200))
    Table FX_FORWARD (FORWARD_ID VARCHAR(200) PRIMARY KEY, BASE_CURRENCY VARCHAR(200), QUOTE_CURRENCY VARCHAR(200), FORWARD_RATE DOUBLE, SPOT_RATE DOUBLE, FORWARD_POINTS DOUBLE, NOTIONAL_BASE DOUBLE, NOTIONAL_QUOTE DOUBLE, VALUE_DATE DATE, TRADE_DATE DATE, TENOR VARCHAR(200), IS_NDF BOOLEAN, INSTRUMENT_ID VARCHAR(200))
    Table SWAP (SWAP_ID VARCHAR(200) PRIMARY KEY, SWAP_TYPE VARCHAR(200), NOTIONAL DOUBLE, FIXED_RATE DOUBLE, FLOATING_INDEX VARCHAR(200), FLOATING_SPREAD DOUBLE, START_DATE DATE, END_DATE DATE, PAYMENT_FREQUENCY VARCHAR(200), DAY_COUNT_CONVENTION VARCHAR(200), CURRENCY VARCHAR(200), IS_CLEARED BOOLEAN, CLEARING_HOUSE VARCHAR(200), CURRENT_NPV DOUBLE, INSTRUMENT_ID VARCHAR(200))
    Table CREDIT_DEFAULT_SWAP (CDS_ID VARCHAR(200) PRIMARY KEY, REFERENCE_ENTITY VARCHAR(200), NOTIONAL DOUBLE, SPREAD DOUBLE, PREMIUM_LEG DOUBLE, PROTECTION_LEG DOUBLE, MATURITY_DATE DATE, EFFECTIVE_DATE DATE, RECOVERY_RATE DOUBLE, IS_TRIGGERED BOOLEAN, TRIGGER_DATE DATE, CURRENCY VARCHAR(200), SENIORITY VARCHAR(200), INSTRUMENT_ID VARCHAR(200))
    Table STRUCTURED_PRODUCT (PRODUCT_ID VARCHAR(200) PRIMARY KEY, PRODUCT_NAME VARCHAR(200), UNDERLYING_TYPE VARCHAR(200), NOTIONAL DOUBLE, ISSUE_DATE DATE, MATURITY_DATE DATE, KNOCK_IN_BARRIER DOUBLE, KNOCK_OUT_BARRIER DOUBLE, PARTICIPATION_RATE DOUBLE, COUPON_RATE DOUBLE, PRINCIPAL_PROTECTION DOUBLE, CURRENCY VARCHAR(200), INSTRUMENT_ID VARCHAR(200))
    Table ETF (ETF_ID VARCHAR(200) PRIMARY KEY, TICKER VARCHAR(200), FUND_NAME VARCHAR(200), ASSET_CLASS VARCHAR(200), EXPENSE_RATIO DOUBLE, TOTAL_ASSETS DOUBLE, NAV DOUBLE, NAV_DATE DATE, TRACKING_ERROR DOUBLE, INDEX_NAME VARCHAR(200), IS_LEVERAGED BOOLEAN, LEVERAGE_MULTIPLE DOUBLE, DIVIDEND_FREQUENCY VARCHAR(200), INSTRUMENT_ID VARCHAR(200))

    Join Equity_Instrument(EQUITY.INSTRUMENT_ID = INSTRUMENT.INSTRUMENT_ID)
    Join Bond_Instrument(BOND.INSTRUMENT_ID = INSTRUMENT.INSTRUMENT_ID)
    Join Option_Underlying(OPTION.UNDERLYING_ID = INSTRUMENT.INSTRUMENT_ID)
    Join Future_Instrument(FUTURE.INSTRUMENT_ID = INSTRUMENT.INSTRUMENT_ID)
    Join FxForward_Instrument(FX_FORWARD.INSTRUMENT_ID = INSTRUMENT.INSTRUMENT_ID)
    Join Swap_Instrument(SWAP.INSTRUMENT_ID = INSTRUMENT.INSTRUMENT_ID)
    Join CDS_Instrument(CREDIT_DEFAULT_SWAP.INSTRUMENT_ID = INSTRUMENT.INSTRUMENT_ID)
    Join StructuredProduct_Instrument(STRUCTURED_PRODUCT.INSTRUMENT_ID = INSTRUMENT.INSTRUMENT_ID)
    Join ETF_Instrument(ETF.INSTRUMENT_ID = INSTRUMENT.INSTRUMENT_ID)
)


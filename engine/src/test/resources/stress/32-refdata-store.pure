(
    refdata::Currency: Relational {
        ~mainTable [store::DB] CURRENCY
        code: [store::DB] CURRENCY.CODE, name: [store::DB] CURRENCY.NAME, numericCode: [store::DB] CURRENCY.NUMERIC_CODE, minorUnit: [store::DB] CURRENCY.MINOR_UNIT, symbol: [store::DB] CURRENCY.SYMBOL, isActive: [store::DB] CURRENCY.IS_ACTIVE, region: [store::DB] CURRENCY.REGION, isMajor: [store::DB] CURRENCY.IS_MAJOR, centralBank: [store::DB] CURRENCY.CENTRAL_BANK, fixingSource: [store::DB] CURRENCY.FIXING_SOURCE
    }

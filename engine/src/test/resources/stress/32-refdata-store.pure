        ~mainTable [store::DB] EXCHANGE
        mic: [store::DB] EXCHANGE.MIC, name: [store::DB] EXCHANGE.NAME, city: [store::DB] EXCHANGE.CITY, timezone: [store::DB] EXCHANGE.TIMEZONE, openTime: [store::DB] EXCHANGE.OPEN_TIME, closeTime: [store::DB] EXCHANGE.CLOSE_TIME, isElectronic: [store::DB] EXCHANGE.IS_ELECTRONIC, operatingMic: [store::DB] EXCHANGE.OPERATING_MIC, website: [store::DB] EXCHANGE.WEBSITE, regulatoryBody: [store::DB] EXCHANGE.REGULATORY_BODY

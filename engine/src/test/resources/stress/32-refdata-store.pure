Database store::DB
(
    Table CURRENCY (CODE VARCHAR(200) PRIMARY KEY, NAME VARCHAR(200), NUMERIC_CODE INTEGER, MINOR_UNIT INTEGER, SYMBOL VARCHAR(200), IS_ACTIVE BOOLEAN, REGION VARCHAR(200), IS_MAJOR BOOLEAN, CENTRAL_BANK VARCHAR(200), FIXING_SOURCE VARCHAR(200), COUNTRY_ID VARCHAR(200))
    Table EXCHANGE (MIC VARCHAR(200) PRIMARY KEY, NAME VARCHAR(200), CITY VARCHAR(200), TIMEZONE VARCHAR(200), OPEN_TIME VARCHAR(200), CLOSE_TIME VARCHAR(200), IS_ELECTRONIC BOOLEAN, OPERATING_MIC VARCHAR(200), WEBSITE VARCHAR(200), REGULATORY_BODY VARCHAR(200), COUNTRY_ID VARCHAR(200))
    Table SECTOR (SECTOR_ID VARCHAR(200) PRIMARY KEY, NAME VARCHAR(200), GICS_CODE VARCHAR(200), LEVEL INTEGER, DESCRIPTION VARCHAR(200), IS_ACTIVE BOOLEAN, PARENT_SECTOR_ID VARCHAR(200), MARKET_CAP_WEIGHT DOUBLE, NUMBER_OF_COMPANIES INTEGER, LAST_UPDATED DATE)
    Table INDUSTRY (INDUSTRY_ID VARCHAR(200) PRIMARY KEY, NAME VARCHAR(200), SIC_CODE VARCHAR(200), NAICS_CODE VARCHAR(200), DESCRIPTION VARCHAR(200), IS_ACTIVE BOOLEAN, SUB_INDUSTRY_OF VARCHAR(200), AVERAGE_PE DOUBLE, AVERAGE_DIVIDEND_YIELD DOUBLE, LAST_UPDATED DATE, SECTOR_ID VARCHAR(200))
    Table ISSUER (ISSUER_ID VARCHAR(200) PRIMARY KEY, NAME VARCHAR(200), LEI VARCHAR(200), TICKER VARCHAR(200), CREDIT_RATING VARCHAR(200), RATING_AGENCY VARCHAR(200), DOMICILE VARCHAR(200), ISSUER_TYPE VARCHAR(200), IS_ACTIVE BOOLEAN, INCORPORATION_DATE DATE, TOTAL_DEBT_OUTSTANDING DOUBLE, WEBSITE VARCHAR(200), COUNTRY_ID VARCHAR(200))
    Table COUNTRY (COUNTRY_CODE VARCHAR(200) PRIMARY KEY, NAME VARCHAR(200), ISO3_CODE VARCHAR(200), REGION VARCHAR(200), SUB_REGION VARCHAR(200), CONTINENT VARCHAR(200), CAPITAL_CITY VARCHAR(200), TIME_ZONE VARCHAR(200), GDP DOUBLE, POPULATION INTEGER, IS_EU BOOLEAN, IS_OECD BOOLEAN)
    Table CALENDAR (CALENDAR_ID VARCHAR(200) PRIMARY KEY, NAME VARCHAR(200), CALENDAR_TYPE VARCHAR(200), YEAR INTEGER, NUMBER_OF_HOLIDAYS INTEGER, IS_ACTIVE BOOLEAN, SOURCE VARCHAR(200), LAST_UPDATED DATE, DESCRIPTION VARCHAR(200), TIMEZONE VARCHAR(200), COUNTRY_ID VARCHAR(200))
    Table RATING (RATING_ID VARCHAR(200) PRIMARY KEY, AGENCY VARCHAR(200), RATING_VALUE VARCHAR(200), RATING_DATE DATE, OUTLOOK VARCHAR(200), WATCH_STATUS VARCHAR(200), IS_INVESTMENT_GRADE BOOLEAN, PREVIOUS_RATING VARCHAR(200), PREVIOUS_DATE DATE, RATING_TYPE VARCHAR(200), SECTOR VARCHAR(200), ISSUER_ID VARCHAR(200))
    Table INDEX (INDEX_ID VARCHAR(200) PRIMARY KEY, NAME VARCHAR(200), TICKER VARCHAR(200), PROVIDER VARCHAR(200), ASSET_CLASS VARCHAR(200), GEOGRAPHY VARCHAR(200), CURRENCY VARCHAR(200), NUMBER_OF_CONSTITUENTS INTEGER, LAUNCH_DATE DATE, REBALANCE_FREQUENCY VARCHAR(200), METHODOLOGY VARCHAR(200), LAST_LEVEL DOUBLE, LAST_LEVEL_DATE DATE)
    Table INDEX_CONSTITUENT (CONSTITUENT_ID VARCHAR(200) PRIMARY KEY, EFFECTIVE_DATE DATE, WEIGHT DOUBLE, SHARES_HELD DOUBLE, MARKET_CAP DOUBLE, FREE_FLOAT_FACTOR DOUBLE, ADDED_DATE DATE, REMOVED_DATE DATE, IS_ACTIVE BOOLEAN, SECTOR VARCHAR(200), INDEX_ID VARCHAR(200))

    Join Sector_Industry(INDUSTRY.SECTOR_ID = SECTOR.SECTOR_ID)
    Join Country_Exchange(EXCHANGE.COUNTRY_ID = COUNTRY.COUNTRY_CODE)
    Join Issuer_Country(ISSUER.COUNTRY_ID = COUNTRY.COUNTRY_CODE)
    Join Index_IndexConstituent(INDEX_CONSTITUENT.INDEX_ID = INDEX.INDEX_ID)
    Join Rating_Issuer(RATING.ISSUER_ID = ISSUER.ISSUER_ID)
    Join Calendar_Country(CALENDAR.COUNTRY_ID = COUNTRY.COUNTRY_CODE)
    Join Currency_Country(CURRENCY.COUNTRY_ID = COUNTRY.COUNTRY_CODE)
)


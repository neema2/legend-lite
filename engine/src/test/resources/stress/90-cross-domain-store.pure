// Cross-Domain Joins

Database store::DB
(
    Join Trade_Instrument(TRADE.INSTRUMENT_ID = INSTRUMENT.INSTRUMENT_ID)
    Join Order_Instrument(ORDER.INSTRUMENT_ID = INSTRUMENT.INSTRUMENT_ID)
    Join Trade_Book(TRADE.BOOK_ID = BOOK.BOOK_ID)
    Join Allocation_Book(ALLOCATION.BOOK_ID = BOOK.BOOK_ID)
    Join Trade_Trader(TRADE.TRADER_ID = TRADER.TRADER_ID)
    Join Trade_Counterparty(TRADE.COUNTERPARTY_ID = COUNTERPARTY.COUNTERPARTY_ID)
    Join Book_Desk(BOOK.DESK_ID = DESK.DESK_ID)
    Join Portfolio_PortfolioManager(PORTFOLIO.PM_ID = PORTFOLIO_MANAGER.PM_ID)
    Join Position_Instrument(POSITION.INSTRUMENT_ID = INSTRUMENT.INSTRUMENT_ID)
    Join Settlement_Trade(SETTLEMENT.TRADE_ID = TRADE.TRADE_ID)
    Join CorporateAction_Instrument(CORPORATE_ACTION.INSTRUMENT_ID = INSTRUMENT.INSTRUMENT_ID)
    Join DailyPnL_Book(DAILY_PN_L.BOOK_ID = BOOK.BOOK_ID)
    Join DailyPnL_Trader(DAILY_PN_L.TRADER_ID = TRADER.TRADER_ID)
    Join DailyPnL_Desk(DAILY_PN_L.DESK_ID = DESK.DESK_ID)
    Join VaRResult_Portfolio(VA_RRESULT.PORTFOLIO_ID = PORTFOLIO.PORTFOLIO_ID)
    Join Greeks_Position(GREEKS.POSITION_ID = POSITION.POSITION_ID)
    Join RiskLimit_Desk(RISK_LIMIT.DESK_ID = DESK.DESK_ID)
    Join CollateralAgreement_Counterparty(COLLATERAL_AGREEMENT.COUNTERPARTY_ID = COUNTERPARTY.COUNTERPARTY_ID)
    Join MarginCall_Counterparty(MARGIN_CALL.COUNTERPARTY_ID = COUNTERPARTY.COUNTERPARTY_ID)
    Join ClientCoverage_Counterparty(CLIENT_COVERAGE.COUNTERPARTY_ID = COUNTERPARTY.COUNTERPARTY_ID)
    Join SalesCredit_Trade(SALES_CREDIT.TRADE_ID = TRADE.TRADE_ID)
    Join SalesPerson_Desk(SALES_PERSON.DESK_ID = DESK.DESK_ID)
    Join Confirmation_Trade(CONFIRMATION.TRADE_ID = TRADE.TRADE_ID)
    Join TradeException_Trade(TRADE_EXCEPTION.TRADE_ID = TRADE.TRADE_ID)
    Join TradeReport_Trade(TRADE_REPORT.TRADE_ID = TRADE.TRADE_ID)
    Join TransactionCost_Execution(TRANSACTION_COST.EXECUTION_ID = EXECUTION.EXECUTION_ID)
    Join Instrument_Sector(INSTRUMENT.SECTOR_ID = SECTOR.SECTOR_ID)
    Join Instrument_Currency(INSTRUMENT.CURRENCY_CODE = CURRENCY.CODE)
    Join Instrument_Exchange(INSTRUMENT.EXCHANGE_MIC = EXCHANGE.MIC)
    Join Bond_Issuer(BOND.ISSUER_ID = ISSUER.ISSUER_ID)
    Join Counterparty_Country(COUNTERPARTY.COUNTRY_CODE = COUNTRY.COUNTRY_CODE)
    Join MarketQuote_Instrument(MARKET_QUOTE.INSTRUMENT_ID = INSTRUMENT.INSTRUMENT_ID)
    Join CashFlow_Book(CASH_FLOW.BOOK_ID = BOOK.BOOK_ID)
    Join TaxLot_Position(TAX_LOT.POSITION_ID = POSITION.POSITION_ID)
    Join AnalystRecommendation_Instrument(ANALYST_RECOMMENDATION.INSTRUMENT_ID = INSTRUMENT.INSTRUMENT_ID)
    Join ClearedTrade_Trade(CLEARED_TRADE.TRADE_ID = TRADE.TRADE_ID)
    Join PBAccount_Counterparty(PRIME_BROKER_ACCOUNT.COUNTERPARTY_ID = COUNTERPARTY.COUNTERPARTY_ID)
    Join SyntheticPosition_Instrument(SYNTHETIC_POSITION.INSTRUMENT_ID = INSTRUMENT.INSTRUMENT_ID)
    Join JournalEntry_CostCenter(JOURNAL_ENTRY.COST_CENTER_ID = COST_CENTER.COST_CENTER_ID)
    Join RegulatoryCapital_LegalEntity(REGULATORY_CAPITAL.LE_ID = LEGAL_ENTITY.LE_ID)
    Join PortfolioManager_Desk(PORTFOLIO_MANAGER.DESK_ID = DESK.DESK_ID)
    Join FxRate_Currency(FX_RATE.BASE_CURRENCY_CODE = CURRENCY.CODE)
    Join Greeks_Instrument(GREEKS.INSTRUMENT_ID = INSTRUMENT.INSTRUMENT_ID)
    Join Settlement_Counterparty(SETTLEMENT.COUNTERPARTY_ID = COUNTERPARTY.COUNTERPARTY_ID)
)

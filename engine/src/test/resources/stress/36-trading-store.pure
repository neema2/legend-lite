Database store::DB
(
    Table TRADE (TRADE_ID VARCHAR(200) PRIMARY KEY, TRADE_DATE DATE, SETTLEMENT_DATE DATE, QUANTITY DOUBLE, PRICE DOUBLE, NOTIONAL DOUBLE, SIDE VARCHAR(200), STATUS VARCHAR(200), TRADE_TYPE VARCHAR(200), CURRENCY VARCHAR(200), COMMISSION DOUBLE, FEES DOUBLE, EXECUTION_VENUE VARCHAR(200), IS_BLOCK BOOLEAN, CREATED_TIME TIMESTAMP, LAST_MODIFIED_TIME TIMESTAMP, ORDER_ID VARCHAR(200), BLOCK_ID VARCHAR(200), AVG_PRICE_TRADE_ID VARCHAR(200), BOOK_ID VARCHAR(200), COUNTERPARTY_ID VARCHAR(200), INSTRUMENT_ID VARCHAR(200), TRADER_ID VARCHAR(200))
    Table ORDER (ORDER_ID VARCHAR(200) PRIMARY KEY, ORDER_DATE DATE, SIDE VARCHAR(200), QUANTITY DOUBLE, FILLED_QUANTITY DOUBLE, REMAINING_QUANTITY DOUBLE, LIMIT_PRICE DOUBLE, STOP_PRICE DOUBLE, TIME_IN_FORCE VARCHAR(200), STATUS VARCHAR(200), PRIORITY INTEGER, CREATED_TIME TIMESTAMP, LAST_MODIFIED_TIME TIMESTAMP, EXPIRY_DATE DATE, IS_ALGO_ORDER BOOLEAN, ALGO_STRATEGY VARCHAR(200), INSTRUMENT_ID VARCHAR(200))
    Table EXECUTION (EXECUTION_ID VARCHAR(200) PRIMARY KEY, EXECUTION_TIME TIMESTAMP, FILLED_QUANTITY DOUBLE, FILL_PRICE DOUBLE, VENUE VARCHAR(200), BROKER VARCHAR(200), COMMISSION DOUBLE, FILL_TYPE VARCHAR(200), EXECUTION_ALGO VARCHAR(200), ARRIVAL_PRICE DOUBLE, SLIPPAGE DOUBLE, MARKET_IMPACT DOUBLE, IS_PARTIAL_FILL BOOLEAN, SEQUENCE_NUMBER INTEGER, LAST_MARKET VARCHAR(200), ORDER_ID VARCHAR(200))
    Table ALLOCATION (ALLOCATION_ID VARCHAR(200) PRIMARY KEY, QUANTITY DOUBLE, PRICE DOUBLE, NOTIONAL DOUBLE, ACCOUNT VARCHAR(200), ALLOCATION_DATE DATE, STATUS VARCHAR(200), COMMISSION DOUBLE, FEES DOUBLE, SETTLEMENT_DATE DATE, CURRENCY VARCHAR(200), IS_CONFIRMED BOOLEAN, TRADE_ID VARCHAR(200), BOOK_ID VARCHAR(200))
    Table TRADE_LIFECYCLE_EVENT (EVENT_ID VARCHAR(200) PRIMARY KEY, EVENT_TYPE VARCHAR(200), EVENT_DATE TIMESTAMP, REASON VARCHAR(200), PREVIOUS_VALUE VARCHAR(200), NEW_VALUE VARCHAR(200), FIELD_CHANGED VARCHAR(200), PERFORMED_BY VARCHAR(200), IS_SYSTEM_GENERATED BOOLEAN, APPROVED_BY VARCHAR(200), APPROVAL_DATE TIMESTAMP, COMMENT VARCHAR(200), TRADE_ID VARCHAR(200))
    Table BLOCK (BLOCK_ID VARCHAR(200) PRIMARY KEY, BLOCK_DATE DATE, TOTAL_QUANTITY DOUBLE, AVERAGE_PRICE DOUBLE, TOTAL_NOTIONAL DOUBLE, NUMBER_OF_ALLOCATIONS INTEGER, STATUS VARCHAR(200), SIDE VARCHAR(200), CURRENCY VARCHAR(200), BROKER VARCHAR(200), IS_COMPLETE BOOLEAN, COMPLETED_TIME TIMESTAMP)
    Table ORDER_ROUTE (ROUTE_ID VARCHAR(200) PRIMARY KEY, ROUTE_DATE TIMESTAMP, DESTINATION VARCHAR(200), ROUTE_QUANTITY DOUBLE, ROUTED_PRICE DOUBLE, STATUS VARCHAR(200), ROUTE_TYPE VARCHAR(200), PRIORITY INTEGER, LATENCY_MS INTEGER, IS_SMART_ROUTED BOOLEAN, REJECT_REASON VARCHAR(200), BROKER VARCHAR(200), ORDER_ID VARCHAR(200))
    Table FILL_DETAIL (FILL_ID VARCHAR(200) PRIMARY KEY, FILL_TIME TIMESTAMP, FILL_QUANTITY DOUBLE, FILL_PRICE DOUBLE, VENUE VARCHAR(200), COUNTERPARTY_ID VARCHAR(200), LIQUIDITY_TYPE VARCHAR(200), IS_MIDPOINT BOOLEAN, IS_DARK_POOL BOOLEAN, SEQUENCE_NUMBER INTEGER, FEES DOUBLE, REBATE DOUBLE, EXECUTION_ID VARCHAR(200))
    Table TRADE_CORRECTION (CORRECTION_ID VARCHAR(200) PRIMARY KEY, CORRECTION_DATE TIMESTAMP, CORRECTION_TYPE VARCHAR(200), ORIGINAL_VALUE VARCHAR(200), CORRECTED_VALUE VARCHAR(200), FIELD_CORRECTED VARCHAR(200), REASON VARCHAR(200), PERFORMED_BY VARCHAR(200), APPROVED_BY VARCHAR(200), STATUS VARCHAR(200), IS_REVERSED BOOLEAN, TRADE_ID VARCHAR(200))
    Table AVERAGE_PRICE_TRADE (AVG_TRADE_ID VARCHAR(200) PRIMARY KEY, AVG_PRICE DOUBLE, TOTAL_QUANTITY DOUBLE, TOTAL_NOTIONAL DOUBLE, NUMBER_OF_FILLS INTEGER, VWAP_PRICE DOUBLE, TWAP_PRICE DOUBLE, ARRIVAL_PRICE DOUBLE, CLOSE_PRICE DOUBLE, TRADE_DATE DATE, SIDE VARCHAR(200), CURRENCY VARCHAR(200))

    Join Order_Trade(TRADE.ORDER_ID = ORDER.ORDER_ID)
    Join Order_Execution(EXECUTION.ORDER_ID = ORDER.ORDER_ID)
    Join Trade_Allocation(ALLOCATION.TRADE_ID = TRADE.TRADE_ID)
    Join Trade_LifecycleEvent(TRADE_LIFECYCLE_EVENT.TRADE_ID = TRADE.TRADE_ID)
    Join Trade_Block(TRADE.BLOCK_ID = BLOCK.BLOCK_ID)
    Join Order_OrderRoute(ORDER_ROUTE.ORDER_ID = ORDER.ORDER_ID)
    Join Execution_FillDetail(FILL_DETAIL.EXECUTION_ID = EXECUTION.EXECUTION_ID)
    Join Trade_TradeCorrection(TRADE_CORRECTION.TRADE_ID = TRADE.TRADE_ID)
    Join Trade_AveragePriceTrade(TRADE.AVG_PRICE_TRADE_ID = AVERAGE_PRICE_TRADE.AVG_TRADE_ID)
)


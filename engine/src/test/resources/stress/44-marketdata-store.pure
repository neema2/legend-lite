Database store::DB
(
    Table MARKET_QUOTE (QUOTE_ID VARCHAR(200) PRIMARY KEY, QUOTE_TIME TIMESTAMP, BID DOUBLE, ASK DOUBLE, MID DOUBLE, LAST DOUBLE, VOLUME DOUBLE, OPEN_PRICE DOUBLE, HIGH_PRICE DOUBLE, LOW_PRICE DOUBLE, CLOSE_PRICE DOUBLE, SOURCE VARCHAR(200), IS_DELAYED BOOLEAN, SNAPSHOT_ID VARCHAR(200), INSTRUMENT_ID VARCHAR(200))
    Table FX_RATE (RATE_ID VARCHAR(200) PRIMARY KEY, CURRENCY_PAIR VARCHAR(200), SPOT_RATE DOUBLE, BID_RATE DOUBLE, ASK_RATE DOUBLE, RATE_DATE TIMESTAMP, SOURCE VARCHAR(200), MID_RATE DOUBLE, DAILY_CHANGE DOUBLE, DAILY_CHANGE_PCT DOUBLE, IS_OFFICIAL BOOLEAN, FIXING_TIME VARCHAR(200), SNAPSHOT_ID VARCHAR(200), BASE_CURRENCY_CODE VARCHAR(200))
    Table VOLATILITY_SURFACE (SURFACE_ID VARCHAR(200) PRIMARY KEY, SURFACE_DATE DATE, UNDERLYING VARCHAR(200), SURFACE_TYPE VARCHAR(200), ATM_VOL DOUBLE, SKEW25_D DOUBLE, BUTTERFLY25_D DOUBLE, RISK_REVERSAL25_D DOUBLE, SOURCE VARCHAR(200), MODEL VARCHAR(200), IS_EOD BOOLEAN, LAST_UPDATED TIMESTAMP)
    Table YIELD_CURVE (CURVE_ID VARCHAR(200) PRIMARY KEY, CURVE_DATE DATE, CURVE_NAME VARCHAR(200), CURRENCY VARCHAR(200), CURVE_TYPE VARCHAR(200), INTERPOLATION VARCHAR(200), POINT_COUNT INTEGER, SOURCE VARCHAR(200), IS_OFFICIAL BOOLEAN, OVERNIGHT_RATE DOUBLE, ONE_YEAR_RATE DOUBLE, TEN_YEAR_RATE DOUBLE, THIRTY_YEAR_RATE DOUBLE, LAST_UPDATED TIMESTAMP)
    Table CREDIT_SPREAD (SPREAD_ID VARCHAR(200) PRIMARY KEY, SPREAD_DATE DATE, REFERENCE_ENTITY VARCHAR(200), TENOR VARCHAR(200), SPREAD DOUBLE, PREVIOUS_SPREAD DOUBLE, CHANGE_AMOUNT DOUBLE, SENIORITY VARCHAR(200), CURRENCY VARCHAR(200), SOURCE VARCHAR(200), IS_INVERTED BOOLEAN, RECOVERY_RATE DOUBLE)
    Table BENCHMARK_RATE (RATE_ID VARCHAR(200) PRIMARY KEY, RATE_NAME VARCHAR(200), RATE_DATE DATE, RATE_VALUE DOUBLE, PREVIOUS_RATE DOUBLE, CHANGE_AMOUNT DOUBLE, TENOR VARCHAR(200), CURRENCY VARCHAR(200), SOURCE VARCHAR(200), IS_OFFICIAL BOOLEAN, FIXING_TIME VARCHAR(200), ADMINISTRATOR VARCHAR(200), YIELD_CURVE_ID VARCHAR(200))
    Table CORPORATE_SPREAD (SPREAD_ID VARCHAR(200) PRIMARY KEY, SPREAD_DATE DATE, SECTOR VARCHAR(200), RATING VARCHAR(200), TENOR VARCHAR(200), SPREAD DOUBLE, BENCHMARK_SPREAD DOUBLE, Z_SPREAD DOUBLE, OAS_SPREAD DOUBLE, CURRENCY VARCHAR(200), SOURCE VARCHAR(200), NUMBER_OF_BONDS INTEGER)
    Table DIVIDEND_FORECAST (FORECAST_ID VARCHAR(200) PRIMARY KEY, EX_DATE DATE, PAYMENT_DATE DATE, AMOUNT DOUBLE, CURRENCY VARCHAR(200), DIVIDEND_TYPE VARCHAR(200), FREQUENCY VARCHAR(200), YIELD DOUBLE, IS_CONFIRMED BOOLEAN, SOURCE VARCHAR(200), PREVIOUS_AMOUNT DOUBLE, GROWTH_RATE DOUBLE)
    Table IMPLIED_VOL_POINT (POINT_ID VARCHAR(200) PRIMARY KEY, VOL_DATE DATE, STRIKE DOUBLE, EXPIRY DATE, IMPLIED_VOL DOUBLE, DELTA DOUBLE, MONEYNESS DOUBLE, SOURCE VARCHAR(200), MODEL VARCHAR(200), IS_ATM BOOLEAN, BID_VOL DOUBLE, ASK_VOL DOUBLE, SURFACE_ID VARCHAR(200))
    Table MARKET_DATA_SNAPSHOT (SNAPSHOT_ID VARCHAR(200) PRIMARY KEY, SNAPSHOT_TIME TIMESTAMP, SNAPSHOT_TYPE VARCHAR(200), SOURCE VARCHAR(200), ITEM_COUNT INTEGER, IS_COMPLETE BOOLEAN, IS_OFFICIAL BOOLEAN, STATUS VARCHAR(200), PROCESSING_TIME_MS INTEGER, VERSION INTEGER, DESCRIPTION VARCHAR(200))

    Join VolatilitySurface_ImpliedVolPoint(IMPLIED_VOL_POINT.SURFACE_ID = VOLATILITY_SURFACE.SURFACE_ID)
    Join YieldCurve_BenchmarkRate(BENCHMARK_RATE.YIELD_CURVE_ID = YIELD_CURVE.CURVE_ID)
    Join MarketDataSnapshot_MarketQuote(MARKET_QUOTE.SNAPSHOT_ID = MARKET_DATA_SNAPSHOT.SNAPSHOT_ID)
    Join MarketDataSnapshot_FxRate(FX_RATE.SNAPSHOT_ID = MARKET_DATA_SNAPSHOT.SNAPSHOT_ID)
)


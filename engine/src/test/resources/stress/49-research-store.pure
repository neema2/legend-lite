Database store::DB
(
    Table ANALYST_RECOMMENDATION (RECOMMENDATION_ID VARCHAR(200) PRIMARY KEY, RECOMMENDATION VARCHAR(200), PREVIOUS_RECOMMENDATION VARCHAR(200), TARGET_PRICE DOUBLE, PREVIOUS_TARGET_PRICE DOUBLE, RATING_DATE DATE, UPSIDE DOUBLE, CONVICTION VARCHAR(200), TIME_HORIZON VARCHAR(200), IS_INITIATION BOOLEAN, SECTOR VARCHAR(200), CURRENCY VARCHAR(200), COMPANY_ID VARCHAR(200), INSTRUMENT_ID VARCHAR(200))
    Table RESEARCH_REPORT (REPORT_ID VARCHAR(200) PRIMARY KEY, TITLE VARCHAR(200), PUBLISH_DATE DATE, REPORT_TYPE VARCHAR(200), PAGE_COUNT INTEGER, IS_PUBLISHED BOOLEAN, ABSTRACT_TEXT VARCHAR(200), SECTOR VARCHAR(200), REGION VARCHAR(200), DOWNLOAD_COUNT INTEGER, LANGUAGE VARCHAR(200), IS_PRIMARY_RESEARCH BOOLEAN, COVERAGE_ID VARCHAR(200))
    Table EARNINGS_ESTIMATE (ESTIMATE_ID VARCHAR(200) PRIMARY KEY, FISCAL_YEAR INTEGER, FISCAL_QUARTER INTEGER, EPS_ESTIMATE DOUBLE, REVENUE_ESTIMATE DOUBLE, PREVIOUS_EPS DOUBLE, PREVIOUS_REVENUE DOUBLE, ESTIMATE_DATE DATE, CURRENCY VARCHAR(200), CONFIDENCE VARCHAR(200), IS_CONSENSUS BOOLEAN, NUMBER_OF_ANALYSTS INTEGER, COMPANY_ID VARCHAR(200))
    Table TARGET_PRICE (TARGET_PRICE_ID VARCHAR(200) PRIMARY KEY, TARGET_PRICE DOUBLE, CURRENT_PRICE DOUBLE, UPSIDE DOUBLE, TARGET_DATE DATE, SET_DATE DATE, METHODOLOGY VARCHAR(200), TIME_HORIZON VARCHAR(200), CURRENCY VARCHAR(200), PREVIOUS_TARGET DOUBLE, CONFIDENCE VARCHAR(200), COMPANY_ID VARCHAR(200))
    Table SECTOR_OUTLOOK (OUTLOOK_ID VARCHAR(200) PRIMARY KEY, SECTOR VARCHAR(200), OUTLOOK VARCHAR(200), PREVIOUS_OUTLOOK VARCHAR(200), OUTLOOK_DATE DATE, KEY_THEME VARCHAR(200), RISK_LEVEL VARCHAR(200), TIME_HORIZON VARCHAR(200), REGION VARCHAR(200), TOP_PICK VARCHAR(200), IS_PUBLISHED BOOLEAN)
    Table COMPANY_PROFILE (PROFILE_ID VARCHAR(200) PRIMARY KEY, COMPANY_NAME VARCHAR(200), TICKER VARCHAR(200), SECTOR VARCHAR(200), MARKET_CAP DOUBLE, EMPLOYEES INTEGER, FOUNDED INTEGER, HEADQUARTERS VARCHAR(200), CEO VARCHAR(200), DESCRIPTION VARCHAR(200), WEBSITE VARCHAR(200), CURRENCY VARCHAR(200), FISCAL_YEAR_END VARCHAR(200), SECTOR_OUTLOOK_ID VARCHAR(200))
    Table PEER_COMPARISON (COMPARISON_ID VARCHAR(200) PRIMARY KEY, COMPARISON_DATE DATE, METRIC VARCHAR(200), VALUE DOUBLE, PEER_AVERAGE DOUBLE, PEER_MEDIAN DOUBLE, PERCENTILE DOUBLE, RANK INTEGER, PEER_GROUP_SIZE INTEGER, IS_ABOVE_PEER BOOLEAN, CURRENCY VARCHAR(200), COMPANY_ID VARCHAR(200))
    Table ANALYST_COVERAGE (COVERAGE_ID VARCHAR(200) PRIMARY KEY, START_DATE DATE, END_DATE DATE, IS_ACTIVE BOOLEAN, REGION VARCHAR(200), SECTOR VARCHAR(200), COVERAGE_TYPE VARCHAR(200), PUBLISHED_REPORT_COUNT INTEGER, LAST_PUBLISH_DATE DATE, ACCURACY DOUBLE)
    Table CONSENSUS_FORECAST (FORECAST_ID VARCHAR(200) PRIMARY KEY, FORECAST_DATE DATE, METRIC VARCHAR(200), CONSENSUS_VALUE DOUBLE, HIGH_ESTIMATE DOUBLE, LOW_ESTIMATE DOUBLE, NUMBER_OF_ESTIMATES INTEGER, STANDARD_DEVIATION DOUBLE, PERIOD VARCHAR(200), CURRENCY VARCHAR(200), PREVIOUS_CONSENSUS DOUBLE, COMPANY_ID VARCHAR(200))
    Table RESEARCH_NOTE (NOTE_ID VARCHAR(200) PRIMARY KEY, NOTE_DATE DATE, NOTE_TYPE VARCHAR(200), SUBJECT VARCHAR(200), CONTENT VARCHAR(200), IS_URGENT BOOLEAN, SENTIMENT VARCHAR(200), IMPACT_LEVEL VARCHAR(200), SECTOR VARCHAR(200), REGION VARCHAR(200), IS_PUBLISHED BOOLEAN, COVERAGE_ID VARCHAR(200))

    Join CompanyProfile_AnalystRecommendation(ANALYST_RECOMMENDATION.COMPANY_ID = COMPANY_PROFILE.PROFILE_ID)
    Join CompanyProfile_EarningsEstimate(EARNINGS_ESTIMATE.COMPANY_ID = COMPANY_PROFILE.PROFILE_ID)
    Join CompanyProfile_TargetPrice(TARGET_PRICE.COMPANY_ID = COMPANY_PROFILE.PROFILE_ID)
    Join CompanyProfile_PeerComparison(PEER_COMPARISON.COMPANY_ID = COMPANY_PROFILE.PROFILE_ID)
    Join AnalystCoverage_ResearchReport(RESEARCH_REPORT.COVERAGE_ID = ANALYST_COVERAGE.COVERAGE_ID)
    Join AnalystCoverage_ResearchNote(RESEARCH_NOTE.COVERAGE_ID = ANALYST_COVERAGE.COVERAGE_ID)
    Join SectorOutlook_CompanyProfile(COMPANY_PROFILE.SECTOR_OUTLOOK_ID = SECTOR_OUTLOOK.OUTLOOK_ID)
    Join ConsensusForecast_CompanyProfile(CONSENSUS_FORECAST.COMPANY_ID = COMPANY_PROFILE.PROFILE_ID)
)


Database store::DB
(
    Table CONFIRMATION (CONFIRM_ID VARCHAR(200) PRIMARY KEY, STATUS VARCHAR(200), SENT_DATE DATE, AFFIRMED_DATE DATE, CONFIRM_METHOD VARCHAR(200), AFFIRMED_BY VARCHAR(200), DAYS_OUTSTANDING INTEGER, IS_OVERDUE BOOLEAN, TEMPLATE_TYPE VARCHAR(200), VERSION INTEGER, LAST_SENT_TIME TIMESTAMP, COUNTERPARTY_REF VARCHAR(200), IS_ELECTRONIC BOOLEAN, TRADE_ID VARCHAR(200))
    Table NETTING_SET (NETTING_SET_ID VARCHAR(200) PRIMARY KEY, AGREEMENT_TYPE VARCHAR(200), EFFECTIVE_DATE DATE, TERMINATION_DATE DATE, CURRENCY VARCHAR(200), IS_ACTIVE BOOLEAN, MEMBER_COUNT INTEGER, LAST_NETTING_DATE DATE, NETTING_FREQUENCY VARCHAR(200), THRESHOLD DOUBLE, DESCRIPTION VARCHAR(200))
    Table NETTING_RESULT (RESULT_ID VARCHAR(200) PRIMARY KEY, NETTING_DATE DATE, GROSS_AMOUNT DOUBLE, NET_AMOUNT DOUBLE, TRADE_COUNT INTEGER, SAVINGS_AMOUNT DOUBLE, SAVINGS_PCT DOUBLE, CURRENCY VARCHAR(200), STATUS VARCHAR(200), IS_FINALIZED BOOLEAN, RUN_TIME TIMESTAMP, VERSION INTEGER, NETTING_SET_ID VARCHAR(200))
    Table TRADE_EXCEPTION (EXCEPTION_ID VARCHAR(200) PRIMARY KEY, EXCEPTION_TYPE VARCHAR(200), SEVERITY VARCHAR(200), DETECTED_DATE TIMESTAMP, DESCRIPTION VARCHAR(200), STATUS VARCHAR(200), ASSIGNED_TO VARCHAR(200), RESOLVED_DATE TIMESTAMP, RESOLVED_BY VARCHAR(200), RESOLUTION VARCHAR(200), AGE_IN_DAYS INTEGER, PRIORITY INTEGER, IS_ESCALATED BOOLEAN, INCIDENT_ID VARCHAR(200), TRADE_ID VARCHAR(200))
    Table BREAK_RESOLUTION (RESOLUTION_ID VARCHAR(200) PRIMARY KEY, RESOLUTION_DATE TIMESTAMP, RESOLUTION_TYPE VARCHAR(200), ACTION VARCHAR(200), PERFORMED_BY VARCHAR(200), APPROVED_BY VARCHAR(200), COMMENT VARCHAR(200), IS_AUTO_RESOLVED BOOLEAN, TIME_TAKEN_MINUTES INTEGER, COST_IMPACT DOUBLE, STATUS VARCHAR(200), TRADE_EXCEPTION_ID VARCHAR(200))
    Table RECONCILIATION_RUN (RUN_ID VARCHAR(200) PRIMARY KEY, RUN_DATE DATE, RUN_TIME TIMESTAMP, SOURCE VARCHAR(200), TARGET VARCHAR(200), TOTAL_ITEMS INTEGER, MATCHED_ITEMS INTEGER, UNMATCHED_ITEMS INTEGER, MATCH_RATE DOUBLE, STATUS VARCHAR(200), DURATION_SECONDS INTEGER, RUN_TYPE VARCHAR(200), IS_AUTOMATIC BOOLEAN)
    Table DATA_QUALITY_ISSUE (ISSUE_ID VARCHAR(200) PRIMARY KEY, ISSUE_TYPE VARCHAR(200), SEVERITY VARCHAR(200), DETECTED_DATE TIMESTAMP, SOURCE VARCHAR(200), FIELD_NAME VARCHAR(200), EXPECTED_VALUE VARCHAR(200), ACTUAL_VALUE VARCHAR(200), STATUS VARCHAR(200), ASSIGNED_TO VARCHAR(200), RESOLVED_DATE TIMESTAMP, IMPACT_SCOPE VARCHAR(200), IS_BLOCKING BOOLEAN, RECONCILIATION_RUN_ID VARCHAR(200))
    Table OPERATIONAL_INCIDENT (INCIDENT_ID VARCHAR(200) PRIMARY KEY, INCIDENT_TYPE VARCHAR(200), SEVERITY VARCHAR(200), OCCURRED_DATE TIMESTAMP, DESCRIPTION VARCHAR(200), IMPACT_ASSESSMENT VARCHAR(200), ROOT_CAUSE VARCHAR(200), STATUS VARCHAR(200), ASSIGNED_TO VARCHAR(200), RESOLVED_DATE TIMESTAMP, LOSS_AMOUNT DOUBLE, CURRENCY VARCHAR(200), IS_REPORTABLE BOOLEAN)
    Table STPRATE (STP_ID VARCHAR(200) PRIMARY KEY, MEASURE_DATE DATE, TOTAL_TRADES INTEGER, STP_TRADES INTEGER, MANUAL_TRADES INTEGER, STP_RATE DOUBLE, ASSET_CLASS VARCHAR(200), REGION VARCHAR(200), TARGET DOUBLE, IS_ABOVE_TARGET BOOLEAN, TREND VARCHAR(200))
    Table PROCESSING_QUEUE (QUEUE_ID VARCHAR(200) PRIMARY KEY, QUEUE_NAME VARCHAR(200), ITEM_COUNT INTEGER, OLDEST_ITEM_DATE TIMESTAMP, PRIORITY VARCHAR(200), STATUS VARCHAR(200), ASSIGNED_TEAM VARCHAR(200), AVG_PROCESSING_TIME_MS INTEGER, SLA_MINUTES INTEGER, IS_BREACHING_SLA BOOLEAN, LAST_PROCESSED_TIME TIMESTAMP, THROUGHPUT_PER_HOUR INTEGER)

    Join NettingSet_NettingResult(NETTING_RESULT.NETTING_SET_ID = NETTING_SET.NETTING_SET_ID)
    Join TradeException_BreakResolution(BREAK_RESOLUTION.TRADE_EXCEPTION_ID = TRADE_EXCEPTION.EXCEPTION_ID)
    Join ReconciliationRun_DataQualityIssue(DATA_QUALITY_ISSUE.RECONCILIATION_RUN_ID = RECONCILIATION_RUN.RUN_ID)
    Join OperationalIncident_TradeException(TRADE_EXCEPTION.INCIDENT_ID = OPERATIONAL_INCIDENT.INCIDENT_ID)
)

Mapping ops::OpsMapping
(
    ops::Confirmation: Relational {
        ~mainTable [store::DB] CONFIRMATION
        confirmId: [store::DB] CONFIRMATION.CONFIRM_ID, status: [store::DB] CONFIRMATION.STATUS, sentDate: [store::DB] CONFIRMATION.SENT_DATE, affirmedDate: [store::DB] CONFIRMATION.AFFIRMED_DATE, confirmMethod: [store::DB] CONFIRMATION.CONFIRM_METHOD, affirmedBy: [store::DB] CONFIRMATION.AFFIRMED_BY, daysOutstanding: [store::DB] CONFIRMATION.DAYS_OUTSTANDING, isOverdue: [store::DB] CONFIRMATION.IS_OVERDUE, templateType: [store::DB] CONFIRMATION.TEMPLATE_TYPE, version: [store::DB] CONFIRMATION.VERSION, lastSentTime: [store::DB] CONFIRMATION.LAST_SENT_TIME, counterpartyRef: [store::DB] CONFIRMATION.COUNTERPARTY_REF, isElectronic: [store::DB] CONFIRMATION.IS_ELECTRONIC
    }

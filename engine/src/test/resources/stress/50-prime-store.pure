Database store::DB
(
    Table PRIME_BROKER_ACCOUNT (PB_ACCOUNT_ID VARCHAR(200) PRIMARY KEY, ACCOUNT_NAME VARCHAR(200), ACCOUNT_TYPE VARCHAR(200), CURRENCY VARCHAR(200), STATUS VARCHAR(200), OPEN_DATE DATE, CLOSE_DATE DATE, MARGIN_TYPE VARCHAR(200), IS_SEGREGATED BOOLEAN, CUSTODIAN VARCHAR(200), LEGAL_ENTITY VARCHAR(200), SERVICE_TIER VARCHAR(200), ANNUAL_FEE DOUBLE, COUNTERPARTY_ID VARCHAR(200))
    Table CLIENT_BALANCE (BALANCE_ID VARCHAR(200) PRIMARY KEY, BALANCE_DATE DATE, CASH_BALANCE DOUBLE, LONG_MARKET_VALUE DOUBLE, SHORT_MARKET_VALUE DOUBLE, NET_EQUITY DOUBLE, MARGIN_REQUIREMENT DOUBLE, EXCESS_DEFICIT DOUBLE, CURRENCY VARCHAR(200), IS_DEFICIT BOOLEAN, PENDING_ACTIVITY DOUBLE, LAST_UPDATED TIMESTAMP, PB_ACCOUNT_ID VARCHAR(200))
    Table FINANCING_RATE (RATE_ID VARCHAR(200) PRIMARY KEY, RATE_DATE DATE, LONG_RATE DOUBLE, SHORT_RATE DOUBLE, SPREAD_BPS DOUBLE, BENCHMARK VARCHAR(200), CURRENCY VARCHAR(200), TIER VARCHAR(200), EFFECTIVE_DATE DATE, EXPIRY_DATE DATE, IS_NEGOTIABLE BOOLEAN, LAST_UPDATED TIMESTAMP, PB_ACCOUNT_ID VARCHAR(200))
    Table MARGIN_REQUIREMENT (MARGIN_ID VARCHAR(200) PRIMARY KEY, CALC_DATE DATE, REG_TMARGIN DOUBLE, HOUSE_MARGIN DOUBLE, CONCENTRATION_MARGIN DOUBLE, TOTAL_MARGIN DOUBLE, CURRENCY VARCHAR(200), METHODOLOGY VARCHAR(200), IS_BREACHED BOOLEAN, BREACH_AMOUNT DOUBLE, CALL_AMOUNT DOUBLE, DUE_DATE DATE, PB_ACCOUNT_ID VARCHAR(200))
    Table SHORT_LOCATE (LOCATE_ID VARCHAR(200) PRIMARY KEY, REQUEST_DATE TIMESTAMP, QUANTITY DOUBLE, LOCATED_QUANTITY DOUBLE, RATE DOUBLE, STATUS VARCHAR(200), EXPIRY_DATE DATE, SOURCE VARCHAR(200), IS_PRE_BORROW BOOLEAN, FILL_PCT DOUBLE, PRIORITY VARCHAR(200), REQUESTED_BY VARCHAR(200), PB_ACCOUNT_ID VARCHAR(200))
    Table BORROW_AVAILABILITY (AVAILABILITY_ID VARCHAR(200) PRIMARY KEY, AVAIL_DATE DATE, AVAILABLE_QUANTITY DOUBLE, BORROWED_QUANTITY DOUBLE, RATE DOUBLE, RATE_TYPE VARCHAR(200), SOURCE VARCHAR(200), IS_EASY_TO_BORROW BOOLEAN, SPECIAL_RATE DOUBLE, LAST_UPDATED TIMESTAMP, EXPIRY_DATE DATE)
    Table SYNTHETIC_POSITION (SYNTHETIC_ID VARCHAR(200) PRIMARY KEY, QUANTITY DOUBLE, ENTRY_PRICE DOUBLE, CURRENT_PRICE DOUBLE, UNREALIZED_PN_L DOUBLE, FINANCING_COST DOUBLE, CURRENCY VARCHAR(200), START_DATE DATE, END_DATE DATE, RESET_FREQUENCY VARCHAR(200), IS_OPEN BOOLEAN, DIVIDEND_ENTITLEMENT DOUBLE, PB_ACCOUNT_ID VARCHAR(200), INSTRUMENT_ID VARCHAR(200))
    Table SWAP_FINANCING (FINANCING_ID VARCHAR(200) PRIMARY KEY, FINANCING_DATE DATE, NOTIONAL DOUBLE, FINANCING_RATE DOUBLE, FINANCING_COST DOUBLE, DAY_COUNT INTEGER, CURRENCY VARCHAR(200), BENCHMARK VARCHAR(200), SPREAD DOUBLE, IS_ACCRUED BOOLEAN, ACCRUAL_PERIOD VARCHAR(200), STATUS VARCHAR(200), SYNTHETIC_POSITION_ID VARCHAR(200))
    Table PORTFOLIO_SWAP (SWAP_ID VARCHAR(200) PRIMARY KEY, SWAP_TYPE VARCHAR(200), NOTIONAL DOUBLE, START_DATE DATE, END_DATE DATE, RESET_DATE DATE, FINANCING_RATE DOUBLE, DIVIDEND_PCT DOUBLE, CURRENCY VARCHAR(200), STATUS VARCHAR(200), NAV DOUBLE, IS_OPEN BOOLEAN, PB_ACCOUNT_ID VARCHAR(200))
    Table CLIENT_STATEMENT (STATEMENT_ID VARCHAR(200) PRIMARY KEY, STATEMENT_DATE DATE, OPENING_BALANCE DOUBLE, CLOSING_BALANCE DOUBLE, TOTAL_DEBITS DOUBLE, TOTAL_CREDITS DOUBLE, FINANCING_CHARGES DOUBLE, FEES DOUBLE, CURRENCY VARCHAR(200), PERIOD VARCHAR(200), STATUS VARCHAR(200), GENERATED_DATE TIMESTAMP, PB_ACCOUNT_ID VARCHAR(200))

    Join PBAccount_ClientBalance(CLIENT_BALANCE.PB_ACCOUNT_ID = PRIME_BROKER_ACCOUNT.PB_ACCOUNT_ID)
    Join PBAccount_FinancingRate(FINANCING_RATE.PB_ACCOUNT_ID = PRIME_BROKER_ACCOUNT.PB_ACCOUNT_ID)
    Join PBAccount_MarginRequirement(MARGIN_REQUIREMENT.PB_ACCOUNT_ID = PRIME_BROKER_ACCOUNT.PB_ACCOUNT_ID)
    Join PBAccount_ShortLocate(SHORT_LOCATE.PB_ACCOUNT_ID = PRIME_BROKER_ACCOUNT.PB_ACCOUNT_ID)
    Join PBAccount_SyntheticPosition(SYNTHETIC_POSITION.PB_ACCOUNT_ID = PRIME_BROKER_ACCOUNT.PB_ACCOUNT_ID)
    Join SyntheticPosition_SwapFinancing(SWAP_FINANCING.SYNTHETIC_POSITION_ID = SYNTHETIC_POSITION.SYNTHETIC_ID)
    Join PBAccount_PortfolioSwap(PORTFOLIO_SWAP.PB_ACCOUNT_ID = PRIME_BROKER_ACCOUNT.PB_ACCOUNT_ID)
    Join PBAccount_ClientStatement(CLIENT_STATEMENT.PB_ACCOUNT_ID = PRIME_BROKER_ACCOUNT.PB_ACCOUNT_ID)
)


Database store::DB
(
    Table COUNTERPARTY (COUNTERPARTY_ID VARCHAR(200) PRIMARY KEY, LEGAL_NAME VARCHAR(200), SHORT_NAME VARCHAR(200), LEI VARCHAR(200), COUNTERPARTY_TYPE VARCHAR(200), DOMICILE VARCHAR(200), INCORPORATION_COUNTRY VARCHAR(200), IS_ACTIVE BOOLEAN, ONBOARD_DATE DATE, CREDIT_RATING VARCHAR(200), RATING_AGENCY VARCHAR(200), TIER VARCHAR(200), PARENT_ENTITY_ID VARCHAR(200), INDUSTRY VARCHAR(200), WEBSITE VARCHAR(200), CLASSIFICATION_ID VARCHAR(200), COUNTRY_CODE VARCHAR(200))
    Table CONTACT (CONTACT_ID VARCHAR(200) PRIMARY KEY, FIRST_NAME VARCHAR(200), LAST_NAME VARCHAR(200), EMAIL VARCHAR(200), PHONE VARCHAR(200), ROLE VARCHAR(200), DEPARTMENT VARCHAR(200), IS_PRIMARY BOOLEAN, IS_ACTIVE BOOLEAN, LAST_CONTACT_DATE DATE, PREFERRED_CHANNEL VARCHAR(200), TITLE VARCHAR(200), COUNTERPARTY_ID VARCHAR(200))
    Table CREDIT_RATING (RATING_ID VARCHAR(200) PRIMARY KEY, AGENCY VARCHAR(200), LONG_TERM_RATING VARCHAR(200), SHORT_TERM_RATING VARCHAR(200), OUTLOOK VARCHAR(200), RATING_DATE DATE, PREVIOUS_RATING VARCHAR(200), PREVIOUS_DATE DATE, WATCH_STATUS VARCHAR(200), IS_INVESTMENT_GRADE BOOLEAN, REVIEW_DATE DATE, ANALYST_NAME VARCHAR(200), COUNTERPARTY_ID VARCHAR(200))
    Table AGREEMENT (AGREEMENT_ID VARCHAR(200) PRIMARY KEY, AGREEMENT_TYPE VARCHAR(200), EFFECTIVE_DATE DATE, TERMINATION_DATE DATE, GOVERNING_LAW VARCHAR(200), STATUS VARCHAR(200), VERSION INTEGER, SIGNED_DATE DATE, LAST_AMEND_DATE DATE, THRESHOLD DOUBLE, MINIMUM_TRANSFER_AMOUNT DOUBLE, INDEPENDENT_AMOUNT DOUBLE, CURRENCY VARCHAR(200), COUNTERPARTY_ID VARCHAR(200))
    Table CLASSIFICATION (CLASSIFICATION_ID VARCHAR(200) PRIMARY KEY, CLASSIFICATION_TYPE VARCHAR(200), MIFID_CLASSIFICATION VARCHAR(200), DODDF_FRANK_CLASSIFICATION VARCHAR(200), EMIR_CLASSIFICATION VARCHAR(200), IS_FINANCIAL_COUNTERPARTY BOOLEAN, IS_SMALL_FINANCIAL BOOLEAN, EFFECTIVE_DATE DATE, REVIEW_DATE DATE, APPROVED_BY VARCHAR(200), NOTES VARCHAR(200), COUNTERPARTY_ID VARCHAR(200))
    Table ACCOUNT (ACCOUNT_ID VARCHAR(200) PRIMARY KEY, ACCOUNT_NAME VARCHAR(200), ACCOUNT_TYPE VARCHAR(200), CURRENCY VARCHAR(200), STATUS VARCHAR(200), OPEN_DATE DATE, CLOSE_DATE DATE, CUSTODIAN VARCHAR(200), BROKER_ID VARCHAR(200), CLEARING_MEMBER_ID VARCHAR(200), MARGIN_TYPE VARCHAR(200), IS_SEGREGATED BOOLEAN, COUNTERPARTY_ID VARCHAR(200))
    Table BENEFICIAL_OWNER (OWNER_ID VARCHAR(200) PRIMARY KEY, NAME VARCHAR(200), OWNERSHIP_PERCENTAGE DOUBLE, NATIONALITY VARCHAR(200), DATE_OF_BIRTH DATE, IS_PEP BOOLEAN, IS_VERIFIED BOOLEAN, VERIFICATION_DATE DATE, ID_TYPE VARCHAR(200), ID_NUMBER VARCHAR(200), ADDRESS VARCHAR(200), COUNTERPARTY_ID VARCHAR(200))
    Table COUNTERPARTY_LIMIT (LIMIT_ID VARCHAR(200) PRIMARY KEY, LIMIT_TYPE VARCHAR(200), LIMIT_AMOUNT DOUBLE, CURRENT_UTILIZATION DOUBLE, UTILIZATION_PCT DOUBLE, CURRENCY VARCHAR(200), EFFECTIVE_DATE DATE, EXPIRY_DATE DATE, STATUS VARCHAR(200), APPROVED_BY VARCHAR(200), APPROVAL_DATE DATE, BREACH_COUNT INTEGER, COUNTERPARTY_ID VARCHAR(200))
    Table KYCRECORD (KYC_ID VARCHAR(200) PRIMARY KEY, STATUS VARCHAR(200), RISK_RATING VARCHAR(200), DUE_DILIGENCE_LEVEL VARCHAR(200), LAST_REVIEW_DATE DATE, NEXT_REVIEW_DATE DATE, REVIEWED_BY VARCHAR(200), APPROVED_BY VARCHAR(200), APPROVAL_DATE DATE, DOCUMENT_COUNT INTEGER, IS_COMPLETE BOOLEAN, EXPIRY_DATE DATE, NOTES VARCHAR(200), COUNTERPARTY_ID VARCHAR(200))
    Table SANCTIONS_CHECK (CHECK_ID VARCHAR(200) PRIMARY KEY, CHECK_DATE TIMESTAMP, SCREENING_PROVIDER VARCHAR(200), RESULT VARCHAR(200), MATCH_COUNT INTEGER, FALSE_POSITIVE_COUNT INTEGER, TRUE_MATCH_COUNT INTEGER, STATUS VARCHAR(200), RESOLVED_DATE TIMESTAMP, RESOLVED_BY VARCHAR(200), LIST_CHECKED VARCHAR(200), IS_CLEARED BOOLEAN, COUNTERPARTY_ID VARCHAR(200))

    Join Counterparty_Contact(CONTACT.COUNTERPARTY_ID = COUNTERPARTY.COUNTERPARTY_ID)
    Join Counterparty_CreditRating(CREDIT_RATING.COUNTERPARTY_ID = COUNTERPARTY.COUNTERPARTY_ID)
    Join Counterparty_Agreement(AGREEMENT.COUNTERPARTY_ID = COUNTERPARTY.COUNTERPARTY_ID)
    Join Counterparty_Classification(CLASSIFICATION.COUNTERPARTY_ID = COUNTERPARTY.COUNTERPARTY_ID)
    Join Counterparty_Account(ACCOUNT.COUNTERPARTY_ID = COUNTERPARTY.COUNTERPARTY_ID)
    Join Counterparty_BeneficialOwner(BENEFICIAL_OWNER.COUNTERPARTY_ID = COUNTERPARTY.COUNTERPARTY_ID)
    Join Counterparty_CounterpartyLimit(COUNTERPARTY_LIMIT.COUNTERPARTY_ID = COUNTERPARTY.COUNTERPARTY_ID)
    Join Counterparty_KYC(KYCRECORD.COUNTERPARTY_ID = COUNTERPARTY.COUNTERPARTY_ID)
    Join Counterparty_SanctionsCheck(SANCTIONS_CHECK.COUNTERPARTY_ID = COUNTERPARTY.COUNTERPARTY_ID)
)


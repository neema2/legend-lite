Database store::DB
(
    Table VA_RRESULT (VAR_ID VARCHAR(200) PRIMARY KEY, CALC_DATE DATE, VAR_AMOUNT DOUBLE, CONFIDENCE_LEVEL DOUBLE, HOLDING_PERIOD INTEGER, METHODOLOGY VARCHAR(200), CURRENCY VARCHAR(200), COMPONENT_VA_R DOUBLE, MARGINAL_VA_R DOUBLE, INCREMENTAL_VA_R DOUBLE, DIVERSIFICATION_BENEFIT DOUBLE, IS_BREACHED BOOLEAN, MODEL VARCHAR(200), RUN_TIME TIMESTAMP, PORTFOLIO_ID VARCHAR(200))
    Table GREEKS (GREEKS_ID VARCHAR(200) PRIMARY KEY, CALC_DATE DATE, DELTA DOUBLE, GAMMA DOUBLE, VEGA DOUBLE, THETA DOUBLE, RHO DOUBLE, CHARM DOUBLE, VANNA DOUBLE, VOLGA DOUBLE, CURRENCY VARCHAR(200), MODEL VARCHAR(200), IS_EOD BOOLEAN, UNDERLYING_PRICE DOUBLE, INSTRUMENT_ID VARCHAR(200), POSITION_ID VARCHAR(200))
    Table RISK_LIMIT (LIMIT_ID VARCHAR(200) PRIMARY KEY, LIMIT_TYPE VARCHAR(200), LIMIT_AMOUNT DOUBLE, CURRENT_UTILIZATION DOUBLE, UTILIZATION_PCT DOUBLE, CURRENCY VARCHAR(200), EFFECTIVE_DATE DATE, EXPIRY_DATE DATE, STATUS VARCHAR(200), APPROVED_BY VARCHAR(200), APPROVAL_DATE DATE, WARNING_THRESHOLD DOUBLE, HARD_LIMIT DOUBLE, IS_ACTIVE BOOLEAN, DESK_ID VARCHAR(200))
    Table LIMIT_BREACH (BREACH_ID VARCHAR(200) PRIMARY KEY, BREACH_DATE TIMESTAMP, BREACH_AMOUNT DOUBLE, SEVERITY VARCHAR(200), STATUS VARCHAR(200), ESCALATION_LEVEL INTEGER, RESOLVED_DATE TIMESTAMP, RESOLVED_BY VARCHAR(200), RESOLUTION VARCHAR(200), PEAK_EXPOSURE DOUBLE, DURATION_MINUTES INTEGER, IS_ACTIVE BOOLEAN, RISK_LIMIT_ID VARCHAR(200))
    Table STRESS_SCENARIO (SCENARIO_ID VARCHAR(200) PRIMARY KEY, NAME VARCHAR(200), CATEGORY VARCHAR(200), DESCRIPTION VARCHAR(200), CREATED_DATE DATE, CREATED_BY VARCHAR(200), IS_ACTIVE BOOLEAN, IS_REGULATORY BOOLEAN, SHOCK_MAGNITUDE DOUBLE, HISTORICAL_DATE DATE, RISK_FACTOR_COUNT INTEGER, LAST_RUN_DATE DATE)
    Table STRESS_RESULT (RESULT_ID VARCHAR(200) PRIMARY KEY, CALC_DATE DATE, STRESSED_PN_L DOUBLE, STRESSED_VA_R DOUBLE, BASELINE_PN_L DOUBLE, DELTA_FROM_BASELINE DOUBLE, CURRENCY VARCHAR(200), MODEL VARCHAR(200), RUN_TIME TIMESTAMP, IS_BREACHED BOOLEAN, BREACH_AMOUNT DOUBLE, CONFIDENCE DOUBLE, SCENARIO_ID VARCHAR(200))
    Table SENSITIVITY_RESULT (SENSITIVITY_ID VARCHAR(200) PRIMARY KEY, SENSITIVITY_TYPE VARCHAR(200), RISK_FACTOR VARCHAR(200), SENSITIVITY_VALUE DOUBLE, CALC_DATE DATE, TENOR VARCHAR(200), CURRENCY VARCHAR(200), MODEL VARCHAR(200), BUMP_SIZE DOUBLE, PREVIOUS_VALUE DOUBLE, CHANGE_AMOUNT DOUBLE, IS_SIGNIFICANT BOOLEAN, RISK_FACTOR_ID VARCHAR(200))
    Table RISK_FACTOR (FACTOR_ID VARCHAR(200) PRIMARY KEY, NAME VARCHAR(200), FACTOR_TYPE VARCHAR(200), ASSET_CLASS VARCHAR(200), CURRENCY VARCHAR(200), TENOR VARCHAR(200), CURRENT_LEVEL DOUBLE, PREVIOUS_LEVEL DOUBLE, DAILY_CHANGE DOUBLE, VOLATILITY DOUBLE, SOURCE VARCHAR(200), LAST_UPDATED TIMESTAMP, IS_ACTIVE BOOLEAN)
    Table EXPOSURE_SNAPSHOT (SNAPSHOT_ID VARCHAR(200) PRIMARY KEY, SNAPSHOT_DATE DATE, GROSS_EXPOSURE DOUBLE, NET_EXPOSURE DOUBLE, LONG_EXPOSURE DOUBLE, SHORT_EXPOSURE DOUBLE, LEVERAGE DOUBLE, CURRENCY VARCHAR(200), ASSET_CLASS VARCHAR(200), REGION VARCHAR(200), IS_EOD BOOLEAN, RUN_TIME TIMESTAMP, VAR_RESULT_ID VARCHAR(200))
    Table CONCENTRATION_RISK (CONCENTRATION_ID VARCHAR(200) PRIMARY KEY, CALC_DATE DATE, DIMENSION_TYPE VARCHAR(200), DIMENSION_VALUE VARCHAR(200), EXPOSURE DOUBLE, EXPOSURE_PCT DOUBLE, LIMIT DOUBLE, IS_BREACHED BOOLEAN, CURRENCY VARCHAR(200), RANK INTEGER, PREVIOUS_EXPOSURE DOUBLE, CHANGE_AMOUNT DOUBLE, VAR_RESULT_ID VARCHAR(200))

    Join RiskLimit_LimitBreach(LIMIT_BREACH.RISK_LIMIT_ID = RISK_LIMIT.LIMIT_ID)
    Join StressScenario_StressResult(STRESS_RESULT.SCENARIO_ID = STRESS_SCENARIO.SCENARIO_ID)
    Join RiskFactor_SensitivityResult(SENSITIVITY_RESULT.RISK_FACTOR_ID = RISK_FACTOR.FACTOR_ID)
    Join VaRResult_ExposureSnapshot(EXPOSURE_SNAPSHOT.VAR_RESULT_ID = VA_RRESULT.VAR_ID)
    Join VaRResult_ConcentrationRisk(CONCENTRATION_RISK.VAR_RESULT_ID = VA_RRESULT.VAR_ID)
)


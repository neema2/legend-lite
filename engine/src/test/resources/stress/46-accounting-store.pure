Database store::DB
(
    Table JOURNAL_ENTRY (ENTRY_ID VARCHAR(200) PRIMARY KEY, ENTRY_DATE DATE, POSTING_DATE DATE, DEBIT_AMOUNT DOUBLE, CREDIT_AMOUNT DOUBLE, CURRENCY VARCHAR(200), DESCRIPTION VARCHAR(200), REFERENCE VARCHAR(200), STATUS VARCHAR(200), POSTED_BY VARCHAR(200), APPROVED_BY VARCHAR(200), IS_REVERSAL BOOLEAN, REVERSAL_OF VARCHAR(200), PERIOD VARCHAR(200), GL_ACCOUNT_ID VARCHAR(200), COST_CENTER_ID VARCHAR(200))
    Table GENERAL_LEDGER_ACCOUNT (ACCOUNT_ID VARCHAR(200) PRIMARY KEY, ACCOUNT_NAME VARCHAR(200), ACCOUNT_NUMBER VARCHAR(200), ACCOUNT_TYPE VARCHAR(200), NORMAL_BALANCE VARCHAR(200), CURRENCY VARCHAR(200), IS_ACTIVE BOOLEAN, PARENT_ACCOUNT_ID VARCHAR(200), LEVEL INTEGER, OPEN_DATE DATE, CLOSE_DATE DATE, DESCRIPTION VARCHAR(200))
    Table SUBLEDGER_ENTRY (SUBLEDGER_ENTRY_ID VARCHAR(200) PRIMARY KEY, ENTRY_DATE DATE, AMOUNT DOUBLE, SUBLEDGER_TYPE VARCHAR(200), REFERENCE VARCHAR(200), CURRENCY VARCHAR(200), STATUS VARCHAR(200), IS_POSTED_TO_GL BOOLEAN, POSTING_DATE DATE, SOURCE VARCHAR(200), LINE_NUMBER INTEGER, DESCRIPTION VARCHAR(200), JOURNAL_ENTRY_ID VARCHAR(200))
    Table ACCOUNTING_RULE (RULE_ID VARCHAR(200) PRIMARY KEY, RULE_NAME VARCHAR(200), RULE_TYPE VARCHAR(200), DEBIT_ACCOUNT_ID VARCHAR(200), CREDIT_ACCOUNT_ID VARCHAR(200), EFFECTIVE_DATE DATE, EXPIRY_DATE DATE, IS_ACTIVE BOOLEAN, PRIORITY INTEGER, CONDITION VARCHAR(200), DESCRIPTION VARCHAR(200), LAST_MODIFIED TIMESTAMP, GL_ACCOUNT_ID VARCHAR(200))
    Table TRIAL_BALANCE (TRIAL_BALANCE_ID VARCHAR(200) PRIMARY KEY, PERIOD_END DATE, TOTAL_DEBITS DOUBLE, TOTAL_CREDITS DOUBLE, IS_BALANCED BOOLEAN, DIFFERENCE DOUBLE, CURRENCY VARCHAR(200), STATUS VARCHAR(200), GENERATED_DATE TIMESTAMP, GENERATED_BY VARCHAR(200), PERIOD VARCHAR(200), VERSION INTEGER)
    Table BALANCE_SHEET (BALANCE_SHEET_ID VARCHAR(200) PRIMARY KEY, REPORT_DATE DATE, TOTAL_ASSETS DOUBLE, TOTAL_LIABILITIES DOUBLE, TOTAL_EQUITY DOUBLE, CURRENCY VARCHAR(200), IS_AUDITED BOOLEAN, PERIOD VARCHAR(200), VERSION INTEGER, PREPARED_BY VARCHAR(200), APPROVED_BY VARCHAR(200), STATUS VARCHAR(200), TRIAL_BALANCE_ID VARCHAR(200))
    Table INCOME_STATEMENT (STATEMENT_ID VARCHAR(200) PRIMARY KEY, PERIOD_START DATE, PERIOD_END DATE, TOTAL_REVENUE DOUBLE, TOTAL_EXPENSES DOUBLE, NET_INCOME DOUBLE, CURRENCY VARCHAR(200), IS_AUDITED BOOLEAN, VERSION INTEGER, PREPARED_BY VARCHAR(200), APPROVED_BY VARCHAR(200), STATUS VARCHAR(200), TRIAL_BALANCE_ID VARCHAR(200))
    Table COST_ALLOCATION (ALLOCATION_ID VARCHAR(200) PRIMARY KEY, ALLOCATION_DATE DATE, AMOUNT DOUBLE, FROM_COST_CENTER VARCHAR(200), TO_COST_CENTER VARCHAR(200), ALLOCATION_BASIS VARCHAR(200), PERCENTAGE DOUBLE, CURRENCY VARCHAR(200), PERIOD VARCHAR(200), STATUS VARCHAR(200), APPROVED_BY VARCHAR(200), IS_REVERSED BOOLEAN)
    Table ACCRUAL_SCHEDULE (SCHEDULE_ID VARCHAR(200) PRIMARY KEY, SCHEDULE_NAME VARCHAR(200), START_DATE DATE, END_DATE DATE, TOTAL_AMOUNT DOUBLE, MONTHLY_AMOUNT DOUBLE, ACCRUED_TO_DATE DOUBLE, REMAINING_AMOUNT DOUBLE, CURRENCY VARCHAR(200), STATUS VARCHAR(200), IS_ACTIVE BOOLEAN, FREQUENCY VARCHAR(200))
    Table AUDIT_TRAIL (AUDIT_ID VARCHAR(200) PRIMARY KEY, AUDIT_DATE TIMESTAMP, ACTION VARCHAR(200), TABLE_NAME VARCHAR(200), RECORD_ID VARCHAR(200), FIELD_NAME VARCHAR(200), OLD_VALUE VARCHAR(200), NEW_VALUE VARCHAR(200), PERFORMED_BY VARCHAR(200), IP_ADDRESS VARCHAR(200), IS_SYSTEM_ACTION BOOLEAN)

    Join JournalEntry_GLAccount(JOURNAL_ENTRY.GL_ACCOUNT_ID = GENERAL_LEDGER_ACCOUNT.ACCOUNT_ID)
    Join SubledgerEntry_JournalEntry(SUBLEDGER_ENTRY.JOURNAL_ENTRY_ID = JOURNAL_ENTRY.ENTRY_ID)
    Join GLAccount_AccountingRule(ACCOUNTING_RULE.GL_ACCOUNT_ID = GENERAL_LEDGER_ACCOUNT.ACCOUNT_ID)
    Join TrialBalance_BalanceSheet(BALANCE_SHEET.TRIAL_BALANCE_ID = TRIAL_BALANCE.TRIAL_BALANCE_ID)
    Join TrialBalance_IncomeStatement(INCOME_STATEMENT.TRIAL_BALANCE_ID = TRIAL_BALANCE.TRIAL_BALANCE_ID)
)


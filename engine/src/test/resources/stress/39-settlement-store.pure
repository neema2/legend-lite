Database store::DB
(
    Table SETTLEMENT (SETTLEMENT_ID VARCHAR(200) PRIMARY KEY, SETTLEMENT_DATE DATE, AMOUNT DOUBLE, CURRENCY VARCHAR(200), STATUS VARCHAR(200), SETTLED_DATE DATE, SETTLEMENT_METHOD VARCHAR(200), CUSTODIAN VARCHAR(200), DEPOSITORY VARCHAR(200), SETTLED_AMOUNT DOUBLE, FAIL_REASON VARCHAR(200), IS_PARTIAL BOOLEAN, PRIORITY INTEGER, LAST_UPDATED TIMESTAMP, NETTING_ID VARCHAR(200), COUNTERPARTY_ID VARCHAR(200), TRADE_ID VARCHAR(200))
    Table SETTLEMENT_INSTRUCTION (INSTRUCTION_ID VARCHAR(200) PRIMARY KEY, INSTRUCTION_TYPE VARCHAR(200), CREATED_DATE TIMESTAMP, EFFECTIVE_DATE DATE, BENEFICIARY_ACCOUNT VARCHAR(200), BENEFICIARY_NAME VARCHAR(200), INTERMEDIARY_BANK VARCHAR(200), SWIFT_CODE VARCHAR(200), IBAN VARCHAR(200), CURRENCY VARCHAR(200), IS_STANDING BOOLEAN, STATUS VARCHAR(200), APPROVED_BY VARCHAR(200), SETTLEMENT_ID VARCHAR(200))
    Table CASH_SETTLEMENT (CASH_SETTLEMENT_ID VARCHAR(200) PRIMARY KEY, PAYMENT_DATE DATE, AMOUNT DOUBLE, CURRENCY VARCHAR(200), PAYMENT_METHOD VARCHAR(200), DEBIT_ACCOUNT VARCHAR(200), CREDIT_ACCOUNT VARCHAR(200), STATUS VARCHAR(200), VALUE_DATE DATE, IS_NETTING BOOLEAN, REFERENCE VARCHAR(200), CONFIRMED_DATE TIMESTAMP, SETTLEMENT_ID VARCHAR(200), NOSTRO_ACCOUNT_ID VARCHAR(200))
    Table SECURITIES_SETTLEMENT (SEC_SETTLEMENT_ID VARCHAR(200) PRIMARY KEY, SETTLEMENT_DATE DATE, QUANTITY DOUBLE, DELIVERY_TYPE VARCHAR(200), CUSTODIAN VARCHAR(200), DEPOSITORY VARCHAR(200), STATUS VARCHAR(200), MATCH_STATUS VARCHAR(200), IS_DELIVERY BOOLEAN, SETTLED_QUANTITY DOUBLE, FAILED_QUANTITY DOUBLE, LAST_UPDATED TIMESTAMP, PRIORITY VARCHAR(200), SETTLEMENT_ID VARCHAR(200))
    Table SETTLEMENT_FAIL (FAIL_ID VARCHAR(200) PRIMARY KEY, FAIL_DATE DATE, FAIL_REASON VARCHAR(200), ORIGINAL_SETTLEMENT_DATE DATE, REVISED_SETTLEMENT_DATE DATE, AMOUNT DOUBLE, CURRENCY VARCHAR(200), PENALTY_AMOUNT DOUBLE, STATUS VARCHAR(200), AGE_IN_DAYS INTEGER, IS_RESOLVED BOOLEAN, RESOLVED_DATE DATE, ESCALATION_LEVEL INTEGER, SETTLEMENT_ID VARCHAR(200))
    Table CORPORATE_ACTION (CORP_ACTION_ID VARCHAR(200) PRIMARY KEY, ACTION_TYPE VARCHAR(200), EX_DATE DATE, RECORD_DATE DATE, PAYMENT_DATE DATE, RATIO DOUBLE, CASH_AMOUNT DOUBLE, CURRENCY VARCHAR(200), STATUS VARCHAR(200), IS_MANDATORY BOOLEAN, ELECTION_DEADLINE DATE, DESCRIPTION VARCHAR(200), ANNOUNCEMENT_DATE DATE, INSTRUMENT_ID VARCHAR(200))
    Table CORPORATE_ACTION_ELECTION (ELECTION_ID VARCHAR(200) PRIMARY KEY, ELECTION_DATE DATE, ELECTION_TYPE VARCHAR(200), QUANTITY DOUBLE, CASH_AMOUNT DOUBLE, STATUS VARCHAR(200), SUBMITTED_BY VARCHAR(200), APPROVED_BY VARCHAR(200), IS_DEFAULT BOOLEAN, DEADLINE DATE, CURRENCY VARCHAR(200), CORPORATE_ACTION_ID VARCHAR(200))
    Table SETTLEMENT_LADDER (LADDER_ID VARCHAR(200) PRIMARY KEY, LADDER_DATE DATE, T0_AMOUNT DOUBLE, T1_AMOUNT DOUBLE, T2_AMOUNT DOUBLE, T3_PLUS_AMOUNT DOUBLE, TOTAL_AMOUNT DOUBLE, CURRENCY VARCHAR(200), DIRECTION VARCHAR(200), ASSET_TYPE VARCHAR(200), IS_PROJECTED BOOLEAN, LAST_UPDATED TIMESTAMP)
    Table NOSTRO_ACCOUNT (ACCOUNT_ID VARCHAR(200) PRIMARY KEY, ACCOUNT_NAME VARCHAR(200), CURRENCY VARCHAR(200), BANK VARCHAR(200), SWIFT_CODE VARCHAR(200), ACCOUNT_NUMBER VARCHAR(200), BALANCE DOUBLE, BALANCE_DATE DATE, IS_ACTIVE BOOLEAN, OPEN_DATE DATE, DAILY_LIMIT DOUBLE, DESCRIPTION VARCHAR(200))
    Table SETTLEMENT_NETTING (NETTING_ID VARCHAR(200) PRIMARY KEY, NETTING_DATE DATE, GROSS_PAY_AMOUNT DOUBLE, GROSS_RECEIVE_AMOUNT DOUBLE, NET_AMOUNT DOUBLE, CURRENCY VARCHAR(200), TRADE_COUNT INTEGER, STATUS VARCHAR(200), IS_MULTILATERAL BOOLEAN, NET_DIRECTION VARCHAR(200), SAVINGS_AMOUNT DOUBLE)

    Join Settlement_Instruction(SETTLEMENT_INSTRUCTION.SETTLEMENT_ID = SETTLEMENT.SETTLEMENT_ID)
    Join Settlement_CashSettlement(CASH_SETTLEMENT.SETTLEMENT_ID = SETTLEMENT.SETTLEMENT_ID)
    Join Settlement_SecuritiesSettlement(SECURITIES_SETTLEMENT.SETTLEMENT_ID = SETTLEMENT.SETTLEMENT_ID)
    Join Settlement_SettlementFail(SETTLEMENT_FAIL.SETTLEMENT_ID = SETTLEMENT.SETTLEMENT_ID)
    Join CorporateAction_Election(CORPORATE_ACTION_ELECTION.CORPORATE_ACTION_ID = CORPORATE_ACTION.CORP_ACTION_ID)
    Join Settlement_Netting(SETTLEMENT.NETTING_ID = SETTLEMENT_NETTING.NETTING_ID)
    Join CashSettlement_NostroAccount(CASH_SETTLEMENT.NOSTRO_ACCOUNT_ID = NOSTRO_ACCOUNT.ACCOUNT_ID)
)


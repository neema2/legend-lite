Database store::DB
(
    Table MARGIN_CALL (MARGIN_CALL_ID VARCHAR(200) PRIMARY KEY, CALL_DATE DATE, CALL_AMOUNT DOUBLE, CURRENCY VARCHAR(200), DIRECTION VARCHAR(200), STATUS VARCHAR(200), RESPONSE_DEADLINE TIMESTAMP, AGREED_AMOUNT DOUBLE, DISPUTED_AMOUNT DOUBLE, CALL_TYPE VARCHAR(200), IS_DISPUTED BOOLEAN, DISPUTE_REASON VARCHAR(200), SETTLED_DATE DATE, VERSION INTEGER, AGREEMENT_ID VARCHAR(200), COUNTERPARTY_ID VARCHAR(200))
    Table COLLATERAL_AGREEMENT (AGREEMENT_ID VARCHAR(200) PRIMARY KEY, AGREEMENT_TYPE VARCHAR(200), EFFECTIVE_DATE DATE, TERMINATION_DATE DATE, MINIMUM_TRANSFER_AMOUNT DOUBLE, THRESHOLD DOUBLE, INDEPENDENT_AMOUNT DOUBLE, ROUNDING_AMOUNT DOUBLE, CURRENCY VARCHAR(200), ELIGIBLE_COLLATERAL VARCHAR(200), VALUATION_FREQUENCY VARCHAR(200), DISPUTE_RESOLUTION_DAYS INTEGER, IS_ACTIVE BOOLEAN, GOVERNING_LAW VARCHAR(200), COUNTERPARTY_ID VARCHAR(200))
    Table COLLATERAL_POSTING (POSTING_ID VARCHAR(200) PRIMARY KEY, AMOUNT DOUBLE, COLLATERAL_TYPE VARCHAR(200), POSTING_DATE DATE, DIRECTION VARCHAR(200), STATUS VARCHAR(200), MARKET_VALUE DOUBLE, HAIRCUT DOUBLE, HAIRCUT_PCT DOUBLE, ADJ_VALUE DOUBLE, CURRENCY VARCHAR(200), CUSTODIAN VARCHAR(200), SETTLED_DATE DATE, MARGIN_CALL_ID VARCHAR(200))
    Table COLLATERAL_BALANCE (BALANCE_ID VARCHAR(200) PRIMARY KEY, BALANCE_DATE DATE, POSTED_AMOUNT DOUBLE, RECEIVED_AMOUNT DOUBLE, NET_AMOUNT DOUBLE, REQUIRED_AMOUNT DOUBLE, EXCESS_DEFICIT DOUBLE, CURRENCY VARCHAR(200), COLLATERAL_TYPE VARCHAR(200), IS_DEFICIT BOOLEAN, LAST_UPDATED TIMESTAMP, AGREEMENT_ID VARCHAR(200))
    Table HAIRCUT_SCHEDULE (HAIRCUT_ID VARCHAR(200) PRIMARY KEY, COLLATERAL_TYPE VARCHAR(200), HAIRCUT DOUBLE, TENOR VARCHAR(200), CREDIT_RATING VARCHAR(200), CURRENCY VARCHAR(200), EFFECTIVE_DATE DATE, EXPIRY_DATE DATE, IS_REGULATORY BOOLEAN, SOURCE VARCHAR(200), AGREEMENT_ID VARCHAR(200))
    Table ELIGIBILITY_RULE (RULE_ID VARCHAR(200) PRIMARY KEY, RULE_NAME VARCHAR(200), COLLATERAL_TYPE VARCHAR(200), MIN_RATING VARCHAR(200), MAX_TENOR VARCHAR(200), MAX_CONCENTRATION DOUBLE, CURRENCY VARCHAR(200), IS_ACTIVE BOOLEAN, EFFECTIVE_DATE DATE, DESCRIPTION VARCHAR(200), PRIORITY INTEGER, AGREEMENT_ID VARCHAR(200))
    Table COLLATERAL_SUBSTITUTION (SUBSTITUTION_ID VARCHAR(200) PRIMARY KEY, REQUEST_DATE DATE, OUT_COLLATERAL_TYPE VARCHAR(200), OUT_AMOUNT DOUBLE, IN_COLLATERAL_TYPE VARCHAR(200), IN_AMOUNT DOUBLE, STATUS VARCHAR(200), APPROVED_BY VARCHAR(200), APPROVAL_DATE DATE, REASON VARCHAR(200), CURRENCY VARCHAR(200), IS_APPROVED BOOLEAN, MARGIN_CALL_ID VARCHAR(200))
    Table INITIAL_MARGIN (IM_ID VARCHAR(200) PRIMARY KEY, CALC_DATE DATE, IM_AMOUNT DOUBLE, METHODOLOGY VARCHAR(200), CURRENCY VARCHAR(200), IS_REGULATORY BOOLEAN, POSTED_AMOUNT DOUBLE, RECEIVED_AMOUNT DOUBLE, EXCESS_DEFICIT DOUBLE, MODEL VARCHAR(200), RUN_TIME TIMESTAMP, VERSION INTEGER, AGREEMENT_ID VARCHAR(200))
    Table VARIATION_MARGIN (VM_ID VARCHAR(200) PRIMARY KEY, CALC_DATE DATE, VM_AMOUNT DOUBLE, MTM DOUBLE, PREVIOUS_MTM DOUBLE, CHANGE_MTM DOUBLE, CURRENCY VARCHAR(200), POSTED_AMOUNT DOUBLE, RECEIVED_AMOUNT DOUBLE, EXCESS_DEFICIT DOUBLE, STATUS VARCHAR(200), LAST_UPDATED TIMESTAMP, AGREEMENT_ID VARCHAR(200))
    Table COLLATERAL_DISPUTE (DISPUTE_ID VARCHAR(200) PRIMARY KEY, DISPUTE_DATE DATE, DISPUTED_AMOUNT DOUBLE, OUR_AMOUNT DOUBLE, THEIR_AMOUNT DOUBLE, REASON VARCHAR(200), STATUS VARCHAR(200), CURRENCY VARCHAR(200), RESOLVED_DATE DATE, RESOLVED_AMOUNT DOUBLE, ESCALATION_LEVEL INTEGER, AGE_IN_DAYS INTEGER, ASSIGNED_TO VARCHAR(200), MARGIN_CALL_ID VARCHAR(200))

    Join MarginCall_Agreement(MARGIN_CALL.AGREEMENT_ID = COLLATERAL_AGREEMENT.AGREEMENT_ID)
    Join MarginCall_Posting(COLLATERAL_POSTING.MARGIN_CALL_ID = MARGIN_CALL.MARGIN_CALL_ID)
    Join Agreement_Balance(COLLATERAL_BALANCE.AGREEMENT_ID = COLLATERAL_AGREEMENT.AGREEMENT_ID)
    Join Agreement_HaircutSchedule(HAIRCUT_SCHEDULE.AGREEMENT_ID = COLLATERAL_AGREEMENT.AGREEMENT_ID)
    Join Agreement_EligibilityRule(ELIGIBILITY_RULE.AGREEMENT_ID = COLLATERAL_AGREEMENT.AGREEMENT_ID)
    Join MarginCall_Substitution(COLLATERAL_SUBSTITUTION.MARGIN_CALL_ID = MARGIN_CALL.MARGIN_CALL_ID)
    Join MarginCall_Dispute(COLLATERAL_DISPUTE.MARGIN_CALL_ID = MARGIN_CALL.MARGIN_CALL_ID)
    Join Agreement_InitialMargin(INITIAL_MARGIN.AGREEMENT_ID = COLLATERAL_AGREEMENT.AGREEMENT_ID)
    Join Agreement_VariationMargin(VARIATION_MARGIN.AGREEMENT_ID = COLLATERAL_AGREEMENT.AGREEMENT_ID)
)


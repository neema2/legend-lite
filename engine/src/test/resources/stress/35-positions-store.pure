Database store::DB
(
    Table BOOK (BOOK_ID VARCHAR(200) PRIMARY KEY, NAME VARCHAR(200), BOOK_TYPE VARCHAR(200), CURRENCY VARCHAR(200), IS_ACTIVE BOOLEAN, OPEN_DATE DATE, CLOSE_DATE DATE, LEGAL_ENTITY VARCHAR(200), STRATEGY VARCHAR(200), PNL_YTD DOUBLE, POSITION_COUNT INTEGER, RISK_LIMIT DOUBLE, DESCRIPTION VARCHAR(200), DESK_ID VARCHAR(200))
    Table POSITION (POSITION_ID VARCHAR(200) PRIMARY KEY, QUANTITY DOUBLE, AVERAGE_COST DOUBLE, MARKET_VALUE DOUBLE, UNREALIZED_PN_L DOUBLE, REALIZED_PN_L DOUBLE, CURRENCY VARCHAR(200), POSITION_DATE DATE, DIRECTION VARCHAR(200), COST_BASIS DOUBLE, ACCRUED_INTEREST DOUBLE, LAST_UPDATED TIMESTAMP, IS_OPEN BOOLEAN, SETTLEMENT_DATE DATE, BOOK_ID VARCHAR(200), PORTFOLIO_ID VARCHAR(200), INSTRUMENT_ID VARCHAR(200))
    Table PORTFOLIO (PORTFOLIO_ID VARCHAR(200) PRIMARY KEY, NAME VARCHAR(200), STRATEGY VARCHAR(200), INCEPTION DATE, AUM DOUBLE, CURRENCY VARCHAR(200), BENCHMARK VARCHAR(200), IS_ACTIVE BOOLEAN, NAV DOUBLE, NAV_DATE DATE, RETURN_YTD DOUBLE, RETURN_MTD DOUBLE, SHARPE_RATIO DOUBLE, MAX_DRAWDOWN DOUBLE, PM_ID VARCHAR(200))
    Table CASH_BALANCE (BALANCE_ID VARCHAR(200) PRIMARY KEY, BALANCE DOUBLE, CURRENCY VARCHAR(200), BALANCE_DATE DATE, BALANCE_TYPE VARCHAR(200), ACCOUNT_ID VARCHAR(200), AVAILABLE_BALANCE DOUBLE, PENDING_AMOUNT DOUBLE, IS_OVERDRAWN BOOLEAN, OVERDRAFT_LIMIT DOUBLE, LAST_UPDATED TIMESTAMP, BOOK_ID VARCHAR(200))
    Table INVENTORY (INVENTORY_ID VARCHAR(200) PRIMARY KEY, AVAILABLE_QUANTITY DOUBLE, LOCKED_QUANTITY DOUBLE, BORROWED_QUANTITY DOUBLE, LENT_QUANTITY DOUBLE, TOTAL_QUANTITY DOUBLE, INVENTORY_DATE DATE, SOURCE VARCHAR(200), LOCATION_TYPE VARCHAR(200), IS_SETTLED BOOLEAN, LAST_UPDATED TIMESTAMP, CUSTODIAN VARCHAR(200), BOOK_ID VARCHAR(200))
    Table LOT_POSITION (LOT_ID VARCHAR(200) PRIMARY KEY, QUANTITY DOUBLE, COST_PRICE DOUBLE, COST_BASIS DOUBLE, ACQUIRE_DATE DATE, LOT_TYPE VARCHAR(200), IS_OPEN BOOLEAN, CLOSE_DATE DATE, CLOSE_PRICE DOUBLE, REALIZED_GAIN DOUBLE, HOLDING_PERIOD INTEGER, TAX_METHOD VARCHAR(200), POSITION_ID VARCHAR(200))
    Table BOOK_TRANSFER (TRANSFER_ID VARCHAR(200) PRIMARY KEY, FROM_BOOK_ID VARCHAR(200), TO_BOOK_ID VARCHAR(200), QUANTITY DOUBLE, PRICE DOUBLE, TRANSFER_DATE DATE, REASON VARCHAR(200), STATUS VARCHAR(200), APPROVED_BY VARCHAR(200), APPROVAL_DATE DATE, CURRENCY VARCHAR(200), NOTIONAL DOUBLE, SOURCE_BOOK_ID VARCHAR(200))
    Table POSITION_BREAK (BREAK_ID VARCHAR(200) PRIMARY KEY, BREAK_TYPE VARCHAR(200), EXPECTED_QUANTITY DOUBLE, ACTUAL_QUANTITY DOUBLE, DIFFERENCE DOUBLE, BREAK_DATE DATE, STATUS VARCHAR(200), PRIORITY VARCHAR(200), ASSIGNED_TO VARCHAR(200), RESOLVED_DATE DATE, RESOLUTION VARCHAR(200), AGE_IN_DAYS INTEGER, POSITION_ID VARCHAR(200))
    Table RECONCILIATION_ITEM (RECON_ID VARCHAR(200) PRIMARY KEY, SOURCE VARCHAR(200), TARGET VARCHAR(200), SOURCE_VALUE DOUBLE, TARGET_VALUE DOUBLE, DIFFERENCE DOUBLE, RECON_DATE DATE, STATUS VARCHAR(200), MATCH_TYPE VARCHAR(200), IS_MATCHED BOOLEAN, COMMENT VARCHAR(200), RESOLVED_BY VARCHAR(200), POSITION_ID VARCHAR(200))
    Table POSITION_SNAPSHOT (SNAPSHOT_ID VARCHAR(200) PRIMARY KEY, SNAPSHOT_DATE DATE, SNAPSHOT_TIME TIMESTAMP, QUANTITY DOUBLE, MARKET_VALUE DOUBLE, UNREALIZED_PN_L DOUBLE, COST_BASIS DOUBLE, CURRENCY VARCHAR(200), SOURCE VARCHAR(200), IS_EOD BOOLEAN, VERSION INTEGER, POSITION_ID VARCHAR(200))

    Join Position_Book(POSITION.BOOK_ID = BOOK.BOOK_ID)
    Join Portfolio_Position(POSITION.PORTFOLIO_ID = PORTFOLIO.PORTFOLIO_ID)
    Join CashBalance_Book(CASH_BALANCE.BOOK_ID = BOOK.BOOK_ID)
    Join Inventory_Book(INVENTORY.BOOK_ID = BOOK.BOOK_ID)
    Join LotPosition_Position(LOT_POSITION.POSITION_ID = POSITION.POSITION_ID)
    Join BookTransfer_Book(BOOK_TRANSFER.SOURCE_BOOK_ID = BOOK.BOOK_ID)
    Join PositionBreak_Position(POSITION_BREAK.POSITION_ID = POSITION.POSITION_ID)
    Join ReconciliationItem_Position(RECONCILIATION_ITEM.POSITION_ID = POSITION.POSITION_ID)
    Join PositionSnapshot_Position(POSITION_SNAPSHOT.POSITION_ID = POSITION.POSITION_ID)
)


Database store::DB
(
    Table CASH_FLOW (CASH_FLOW_ID VARCHAR(200) PRIMARY KEY, AMOUNT DOUBLE, CASH_FLOW_TYPE VARCHAR(200), PAYMENT_DATE DATE, CURRENCY VARCHAR(200), DIRECTION VARCHAR(200), STATUS VARCHAR(200), PROJECTED_DATE DATE, SETTLED_DATE DATE, IS_PROJECTED BOOLEAN, SOURCE VARCHAR(200), REFERENCE VARCHAR(200), PRIORITY INTEGER, BOOK_ID VARCHAR(200))
    Table FUNDING_RATE (RATE_ID VARCHAR(200) PRIMARY KEY, RATE_DATE DATE, RATE_BPS DOUBLE, TENOR VARCHAR(200), RATE_TYPE VARCHAR(200), CURRENCY VARCHAR(200), BENCHMARK VARCHAR(200), SPREAD DOUBLE, ALL_IN_RATE DOUBLE, SOURCE VARCHAR(200), IS_ACTIVE BOOLEAN, LAST_UPDATED TIMESTAMP)
    Table REPO_TRADE (REPO_ID VARCHAR(200) PRIMARY KEY, TRADE_DATE DATE, START_DATE DATE, END_DATE DATE, REPO_RATE DOUBLE, NOTIONAL DOUBLE, COLLATERAL_TYPE VARCHAR(200), HAIRCUT DOUBLE, DIRECTION VARCHAR(200), STATUS VARCHAR(200), CURRENCY VARCHAR(200), IS_OPEN BOOLEAN, MATURITY_TYPE VARCHAR(200), DAILY_ACCRUAL DOUBLE, FUNDING_RATE_ID VARCHAR(200))
    Table SECURITIES_LOAN (LOAN_ID VARCHAR(200) PRIMARY KEY, LOAN_DATE DATE, QUANTITY DOUBLE, LENDING_FEE DOUBLE, REBATE_RATE DOUBLE, COLLATERAL_TYPE VARCHAR(200), COLLATERAL_VALUE DOUBLE, DIRECTION VARCHAR(200), STATUS VARCHAR(200), RETURN_DATE DATE, CURRENCY VARCHAR(200), IS_RECALLABLE BOOLEAN, RECALL_DATE DATE, FUNDING_RATE_ID VARCHAR(200))
    Table FUNDING_REQUIREMENT (REQUIREMENT_ID VARCHAR(200) PRIMARY KEY, REQUIREMENT_DATE DATE, AMOUNT DOUBLE, CURRENCY VARCHAR(200), URGENCY VARCHAR(200), SOURCE VARCHAR(200), STATUS VARCHAR(200), DUE_DATE DATE, FILLED_AMOUNT DOUBLE, GAP_AMOUNT DOUBLE, IS_MET_BY_DEADLINE BOOLEAN, COST_ESTIMATE DOUBLE, LIQUIDITY_POOL_ID VARCHAR(200))
    Table LIQUIDITY_POOL (POOL_ID VARCHAR(200) PRIMARY KEY, POOL_NAME VARCHAR(200), TOTAL_AMOUNT DOUBLE, AVAILABLE_AMOUNT DOUBLE, RESERVED_AMOUNT DOUBLE, CURRENCY VARCHAR(200), POOL_TYPE VARCHAR(200), IS_ACTIVE BOOLEAN, MIN_BALANCE DOUBLE, MAX_CAPACITY DOUBLE, LAST_UPDATED TIMESTAMP)
    Table TREASURY_TRANSACTION (TRANSACTION_ID VARCHAR(200) PRIMARY KEY, TRANSACTION_DATE DATE, AMOUNT DOUBLE, TRANSACTION_TYPE VARCHAR(200), CURRENCY VARCHAR(200), FROM_ACCOUNT VARCHAR(200), TO_ACCOUNT VARCHAR(200), STATUS VARCHAR(200), APPROVED_BY VARCHAR(200), REFERENCE VARCHAR(200), VALUE_DATE DATE, IS_INTERCOMPANY BOOLEAN)
    Table FUNDING_COST (COST_ID VARCHAR(200) PRIMARY KEY, COST_DATE DATE, COST_AMOUNT DOUBLE, COST_TYPE VARCHAR(200), CURRENCY VARCHAR(200), RATE_BPS DOUBLE, NOTIONAL DOUBLE, DAY_COUNT INTEGER, ACCRUAL_PERIOD VARCHAR(200), IS_ALLOCATED BOOLEAN, ALLOCATED_TO VARCHAR(200), CASH_FLOW_ID VARCHAR(200))
    Table INTERCOMPANY_LOAN (LOAN_ID VARCHAR(200) PRIMARY KEY, LENDER VARCHAR(200), BORROWER VARCHAR(200), PRINCIPAL DOUBLE, INTEREST_RATE DOUBLE, START_DATE DATE, MATURITY_DATE DATE, CURRENCY VARCHAR(200), STATUS VARCHAR(200), OUTSTANDING_BALANCE DOUBLE, ACCRUED_INTEREST DOUBLE, IS_SUBORDINATED BOOLEAN)
    Table CASH_FORECAST (FORECAST_ID VARCHAR(200) PRIMARY KEY, FORECAST_DATE DATE, HORIZON VARCHAR(200), PROJECTED_INFLOWS DOUBLE, PROJECTED_OUTFLOWS DOUBLE, NET_CASH_FLOW DOUBLE, OPENING_BALANCE DOUBLE, CLOSING_BALANCE DOUBLE, CURRENCY VARCHAR(200), CONFIDENCE DOUBLE, SCENARIO VARCHAR(200), LAST_UPDATED TIMESTAMP, LIQUIDITY_POOL_ID VARCHAR(200))

    Join CashFlow_FundingCost(FUNDING_COST.CASH_FLOW_ID = CASH_FLOW.CASH_FLOW_ID)
    Join RepoTrade_FundingRate(REPO_TRADE.FUNDING_RATE_ID = FUNDING_RATE.RATE_ID)
    Join SecuritiesLoan_FundingRate(SECURITIES_LOAN.FUNDING_RATE_ID = FUNDING_RATE.RATE_ID)
    Join LiquidityPool_FundingRequirement(FUNDING_REQUIREMENT.LIQUIDITY_POOL_ID = LIQUIDITY_POOL.POOL_ID)
    Join CashForecast_LiquidityPool(CASH_FORECAST.LIQUIDITY_POOL_ID = LIQUIDITY_POOL.POOL_ID)
)

